{
  "title": "Approval Role",
  "description": "Smart Search page for Approval Role management with filters and comprehensive role information display",
  "variables": {
    "encryptedBody": {
      "type": {
        "payload": "string"
      }
    },
    "filterCriterion": {
      "type": "any",
      "onValueChanged": {
        "chains": [
          {
            "parameters": {
              "event": "{{ $event }}"
            },
            "chain": "filterCriterionListener"
          }
        ]
      }
    },
    "getApproverRoleLovRolecodeListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "keyAttributes": "approval_role_code",
        "itemsPath": "items",
        "responseType": "getApproverRoleLovRolecodeResponse",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "approval_role_name"
          ]
        },
        "fetchChain": "getApproverRoleLovRolecodeFetch"
      }
    },
    "pagination": {
      "type": {
        "next": "boolean",
        "prev": "boolean"
      },
      "defaultValue": {
        "next": false,
        "prev": false
      }
    },
    "searchContext": {
      "type": "object",
      "defaultValue": {
        "$search": {
          "filters": {
            "ApprovalRoleNameFilter": {
              "label": "Approval Role Name",
              "options": {
                "optionsData": "[[ $page.variables.getApproverRoleLovRolecodeListSDP ]]",
                "optionsKeys": {
                  "label": "approval_role_name",
                  "value": "approval_role_code"
                }
              }
            }
          }
        }
      }
    },
    "searchConfiguration": {
      "type": "oj-sp/smart-search/strategies/JsonSearchConfigProviderFactory",
      "defaultValue": {
        "url": "[[ $application.path + 'resources/data/approvalUserRoleSearchConfig.json' ]]"
      }
    },
    "searchObj": {
      "type": {
        "IN_LIMIT": "number",
        "IN_OFFSET": "number",
        "KEYWORD": "string",
        "P_APPROVAL_ROLE_ID": "string",
        "APPROVAL_ROLE_CODE": "string",
        "APPROVAL_ROLE_NAME": "string",
        "ACTIVE_FLAG": "string"
      },
      "defaultValue": {
        "IN_LIMIT": 8,
        "IN_OFFSET": 0,
        "P_APPROVAL_ROLE_ID": "",
        "APPROVAL_ROLE_CODE": "",
        "APPROVAL_ROLE_NAME": "",
        "ACTIVE_FLAG": ""
      }
    },
    "approvalRoleRequestADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "ApprovalRoleManagementType",
        "keyAttributes": "approval_role_id"
      }
    }
  },
  "metadata": {},
  "types": {

    "@decorators.getApproverRoleLovRolecodeResponse": {
      "endpoint": "getApproverRoleLovRolecode",
      "service": "ApprovalUserRole",
      "path": "response"
    },
    "ApprovalRoleManagementType": {
      "approval_role_id": "number",
      "object_version_num": "number",
      "approval_role_code": "string",
      "approval_role_name": "string",
      "remarks": "string",
      "active_flag": "string",
      "attribute_json": "string",
      "created_by": "string",
      "created_date": "string",
      "last_updated_by": "string",
      "last_updated_date": "string",
      "last_updated_login": "string"
    },
    "getApproverRoleLovRolecodeResponse": {
      "items": [
        {
          "approval_role_code": "string",
          "approval_role_name": "string"
        }
      ]
    }
  },
  "chains": {},
  "imports": {
    "components": {
      "oj-button": {
        "path": "ojs/ojbutton"
      },
      "oj-dialog": {
        "path": "ojs/ojdialog"
