      "created_by": "string",
      "created_date": "string",
      "last_updated_by": "string",
      "last_updated_date": "string",
      "last_updated_login": "string"
    },
    "ApprovalRoleUser": {
      "approval_role_user_id": "number",
      "object_version_num": "number",
      "approval_role_id": "number",
      "user_id": "number",
      "user_name": "string",
      "order_number": "number",
      "person_id": "number",
      "person_number": "string",
      "person_name": "string",
      "remarks": "string",
      "active_flag": "string",
      "attribute_json": "string",
