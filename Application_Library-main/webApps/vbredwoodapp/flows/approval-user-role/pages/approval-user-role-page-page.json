      "items": [
        {
          "email_address": "string",
          "person_full_name": "string",
          "person_id": "number",
          "person_name": "string",
          "person_number": "string",
          "user_id": "number",
          "user_name": "string"
        }
      ]
    },
    "getApproverRoleLovUserNameResponse": {
      "items": [
        {
          "email_address": "string",
          "person_full_name": "string",
          "person_id": "number",
          "person_name": "string",
          "person_number": "string",
          "user_id": "number",
          "user_name": "string"
        }
      ]
