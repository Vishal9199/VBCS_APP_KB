        "USER_ID": "",
        "PERSON_ID": "",
        "ORDER_NUMBER": "",
        "ACTIVE_FLAG": ""
      }
    },
    "pagination": {
      "type": {
        "next": "boolean",
        "prev": "boolean"
      },
      "defaultValue": {
        "next": false,
        "prev": false
      }
    },
    "key": {
      "type": "string",
      "input": "fromUrl"
    },
    "approvalRoleVar": {
      "type": "ApprovalRole",
      "defaultValue": {
        "active_flag": "Y"
      },
      "input": "none",
      "required": false,
      "dirtyDataBehavior": "track"
    },
    "ADPapprovalRoleUser": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "ApprovalRoleUser",
        "keyAttributes": "approval_role_user_id"
      }
    },
    "approvalRoleUserVar": {
      "type": "ApprovalRoleUser",
      "defaultValue": {
        "active_flag": "Y",
        "object_version_num": 0,
        "approval_role_user_id": 0,
        "remarks": " ",
        "attribute_json": "null"
      }
    },
    "canEdit": {
      "type": "boolean",
      "defaultValue": "[[ $variables.method === \"POST\" ]]"
    },
    "method": {
      "type": "string",
      "defaultValue": "POST",
      "input": "fromUrl"
    },
    "validationGroupVars": {
      "type": {
        "childTableFormId": "string",
        "headerFormId": "string",
        "isChildTableFormValid": "string",
        "isHeaderFormValid": "string"
      },
      "defaultValue": {
        "childTableFormId": "approvalRoleUserForm",
        "headerFormId": "approval-role-validation"
      }
    }

