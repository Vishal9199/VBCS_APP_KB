        "APPROVAL_ROLE_CODE": "",
        "APPROVAL_ROLE_NAME": "",
        "ACTIVE_FLAG": ""
      }
    },
    "searchUserObj": {
      "type": {
        "IN_LIMIT": "number",
        "IN_OFFSET": "number",
        "P_APPROVAL_ROLE_USER_ID": "string",
        "APPROVAL_ROLE_ID": "string",
        "USER_ID": "string",
        "PERSON_ID": "string",
        "ORDER_NUMBER": "string",
        "ACTIVE_FLAG": "string"
