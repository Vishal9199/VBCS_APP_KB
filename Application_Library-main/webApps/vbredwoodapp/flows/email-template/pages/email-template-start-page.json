{
  "title": "Email Template",
  "description": "Smart Search page for Email Template management with filters for Header View Name and keyword search",
  "variables": {
    "filterCriterion": {
      "type": "any",
      "onValueChanged": {
        "chains": [
          {
            "parameters": {
              "event": "{{ $event }}"
            },
            "chain": "filterCriterionListener"
          }
        ]
      }
    },
    "encryptedBody": {
      "type": {
        "payload": "string"
      }
    },
    "getEmailLovTemplate2ListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "keyAttributes": "template_code",
        "itemsPath": "items",
        "responseType": "getEmailLovTemplate2Response",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "template_name"
          ]
        },
        "fetchChain": "getEmailLovTemplate2Fetch"
      }
    },
    "pagination": {
      "type": {
        "next": "boolean",
        "prev": "boolean"
      },
      "defaultValue": {
        "next": false,
        "prev": false
      }
    },
    "searchContext": {
      "type": "object",
      "defaultValue": {
        "$search": {
          "filters": {
            "HeaderTemplateNameFilter": {
              "label": "Template Name",
              "options": {
                "optionsData": "[[ $page.variables.getEmailLovTemplate2ListSDP]]",
                "optionsKeys": {
                  "label": "template_name",
                  "value": "template_code"
                }
              }
            }
          }
        }
      }
    },
    "searchConfiguration": {
      "type": "oj-sp/smart-search/strategies/JsonSearchConfigProviderFactory",
      "defaultValue": {
        "url": "[[ $application.path + 'resources/data/emailSearchConfig.json' ]]"
      }
    },
    "searchObj": {
      "type": {
        "IN_LIMIT": "number",
        "IN_OFFSET": "number",
        "TEMPLATE_CODE": "string",
        "KEYWORD": "string"
      },
      "defaultValue": {
        "IN_LIMIT": 8,
        "IN_OFFSET": 0,
        "TEMPLATE_CODE": "",
        "KEYWORD": ""
      }
    },
    "emailTemplateADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "EmailTemplateType",
        "keyAttributes": "template_id"
      }
    },
    "selectedTemplateForInfo": {
      "type": "EmailTemplateType"
    }

  },
  "metadata": {},
  "types": {
    "@decorators.getEmailLovTemplate2Response": {
      "endpoint": "getEmailLovTemplate2",
      "service": "Application",
      "path": "response"
    },
    "@decorators.getEmailLovViewname": {
      "endpoint": "getEmailLovViewname",
      "service": "Application",
      "path": "response"
    },
    "@decorators.getEmailLovViewnameResponse": {
      "endpoint": "getEmailLovViewname",
      "service": "ORDS_AOL",
      "path": "response"
    },
    "@decorators.getEmailLovViewnameResponse2": {
      "endpoint": "getEmailLovViewname",
      "service": "Application",
      "path": "response"
    },
    "getEmailLovTemplate2Response": {
      "items": [
        {
          "template_code": "string",
          "template_name": "string"
        }
      ]
    },
    "getEmailLovViewname": {
      "items": [
        {
          "header_view_name": "string"
        }
      ]
    },
    "getEmailLovViewnameResponse": {
      "items": [
        {
          "header_view_name": "string"
        }
      ]
    },
    "EmailTemplateType": {
      "template_id": "number",
      "template_code": "string",
      "template_name": "string",
      "header_view_name": "string",
      "header_primary_key": "string",
      "approve_url_template": "string",
      "reject_url_template": "string",
      "report_url_template": "string",
      "is_active": "string",
      "created_by": "string",
      "created_date": "string",
      "last_updated_by": "string",
      "last_updated_date": "string",
      "last_updated_login": "string"
    },
    "getEmailLovViewnameResponse2": {
      "items": [
        {
          "header_view_name": "string"
        }
      ]
    }
  },
  "chains": {},
  "imports": {
    "components": {
      "oj-button": {
        "path": "ojs/ojbutton"
      },
      "oj-dialog": {
        "path": "ojs/ojdialog"
      },
      "oj-input-text": {
        "path": "ojs/ojinputtext"
      },
      "oj-select-single": {
        "path": "ojs/ojselectsingle"
      },
      "oj-sp-smart-search": {
        "path": "oj-sp/smart-search/loader"
      },
      "oj-sp-smart-search-page": {
        "path": "oj-sp/smart-search-page/loader"
      },
      "oj-table": {
        "path": "ojs/ojtable"
      },
      "oj-toolbar": {
        "path": "ojs/ojtoolbar"
      },
      "oj-bind-if": {
        "path": "ojs/ojbindif"
      },
      "oj-switch": {
        "path": "ojs/ojswitch"
      }

    },
    "modules": {
      "ojValidationDateTime": {
        "path": "ojs/ojvalidation-datetime"
      }
    },
    "css": [
      "/resources/css/smartSearch.css"
    ]
  },
  "constants": {
    "tableColumns": {
      "type": "object[]",
      "defaultValue": [
        {
          "headerText": "Actions",
          "field": "",
          "resizable": "enabled",
          "width": 150,
          "sortable": "disabled",
          "template": "actions",
          "headerStyle": "text-align: center; white-space: normal; min-width: 120px;",
          "style": "text-align: center; vertical-align: middle;"
        },
        {
          "headerText": "Template Code",
          "field": "template_code",
          "resizable": "enabled",
          "sortable": "enabled",
          "template": "template_code",
          "headerStyle": "white-space: normal; min-width: 160px;",
          "style": ""
        },
        {
          "headerText": "Template Name",
          "field": "template_name",
          "resizable": "enabled",
          "sortable": "enabled",
          "template": "template_name",
          "headerStyle": "white-space: normal; min-width: 200px;",
          "style": ""
        },
        {
          "headerText": "Header View Name",
          "field": "header_view_name",
          "resizable": "enabled",
          "width": 305,
          "template": "header_view_name",
          "headerStyle": "white-space: normal; min-width: 180px;",
          "style": ""
        },
        {
          "headerText": "Header Primary Key",
          "field": "header_primary_key",
          "resizable": "enabled",
          "width": 200,
          "template": "header_primary_key",
          "headerStyle": "white-space: normal; min-width: 170px;",
          "style": ""
        },
        {
          "headerText": "Status",
          "field": "is_active",
          "resizable": "enabled",
          "width": 200,
          "sortable": "disabled",
          "template": "active_flag",
          "headerStyle": "text-align: center; white-space: normal; min-width: 100px;",
          "style": "text-align: center; vertical-align: middle;"
        }
      ]
    }
  },
  "eventListeners": {
    "addBtnAction": {
      "chains": [
        {
          "chain": "addEmailTemplateAC"
        }
      ]
    },
    "deleteBtnNoAction": {
      "chains": [
        {
          "chain": "cancelDeleteAC"
        }
      ]
    },
    "deleteBtnYesAction": {
      "chains": [
        {
          "chain": "okDeleteAC"
        }
      ]
    },
    "editIconClick": {
      "chains": [
        {
          "chain": "editEmailTemplateAC",
          "parameters": {
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "deleteIconClick": {
      "chains": [
        {
          "chain": "deleteEmailTemplateAC",
          "parameters": {
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "iconClick": {
      "chains": [
        {
          "chain": "IconClickChain2",
          "parameters": {
            "event": "{{$event}}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "infoIconClick": {
      "chains": [
        {
          "chain": "showInfoDialogAC",
          "parameters": {
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "nxtBtnAction": {
      "chains": [
        {
          "chain": "nextBtnAC"
        }
      ]
    },
    "preBtnAction": {
      "chains": [
        {
          "chain": "prevBtnAC"
        }
      ]
    },
    "refreshBtnAction": {
      "chains": [
        {
          "chain": "refreshBtn",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "resetBtnAction": {
      "chains": [
        {
          "chain": "resetAC"
        }
      ]
    },
    "vbAfterNavigate": {
      "chains": [
        {
          "parameters": {
            "event": "{{ $event }}"
          },
          "chain": "vbAfterNavigateListener"
        }
      ]
    }

  }
}