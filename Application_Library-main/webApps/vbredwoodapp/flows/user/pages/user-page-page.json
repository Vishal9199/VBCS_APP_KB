{
  "title": "User Access Management",
  "description": "User Access Management Add/Edit page with header form and User Access Details table with popup dialog editing",
  "variables": {
    "getAolUsrRoleLovRolenameListSDP2": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "keyAttributes": "role_id",
        "itemsPath": "items",
        "responseType": "getAolUsrRoleLovRolenameResponse2",
        "headers": {
          "p_user_id": "{{ $variables.userAccessDetailHeaderVar.user_id }}"
        },
        "transformsContext": {
          "vb-textFilterAttributes": [
            "role_name"
          ]
        },
        "fetchChain": "getAol_usrRoleLovRolenameFetch3"
      }
    },
    "P_KEY": {
      "type": "string",
      "required": true,
      "input": "fromUrl"
    },
    "user_hide": {
      "type": "string"
    },
    "userAccessChildVar": {
      "type": "UserAccessType",
      "defaultValue": {
        "effective_end_date": "4712-12-31",
        "effective_start_date": "[[ $application.functions.removeTimeZone($application.functions.getSysdate()) ]]"
      }
    },
    "userAccessDetailHeaderVar": {
      "type": "UserAccessDetailType"
    },
    "ADPuserAccessDetails": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "UserAccessType",
        "keyAttributes": "user_access_id"
      }
    },
    "searchObj": {
      "type": {
        "IN_LIMIT": "number",
        "IN_OFFSET": "number",
        "P_USER_ACCESS_ID": "number",
        "P_USER_NAME": "string",
        "P_ACTIVE_FLAG": "string",
        "P_EFFECTIVE_START_DATE": "string",
        "P_EFFECTIVE_END_DATE": "string",
        "USER_ID": "number"
      },
      "defaultValue": {
        "IN_OFFSET": 0,
        "IN_LIMIT": 6
      }
 
    },
    "encryptPayload": {
      "type": {
        "payload": "string"
      }
    },
    "pagination": {
      "type": {
        "prev": "boolean",
        "next": "boolean"
      },
      "defaultValue": {
        "prev": false,
        "next": false
      }
    },
    "validform": {
      "type": {
        "isHeaderFormValid": "string",
        "isDialogFormValid": "string"
      },
      "defaultValue": {
        "isHeaderFormValid": "valid",
        "isDialogFormValid": "valid"
      }
    }

