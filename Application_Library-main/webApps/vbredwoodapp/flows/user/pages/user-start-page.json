{
  "title": "User Access Management Smart Search",
  "description": "Smart Search page for User Access Management with filtering, search and table display functionality",
  "variables": {
    "encryptPayload": {
      "type": {
        "payload": "string"
      }
    },
    "getAolUsrRoleLovUserNameListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "keyAttributes": "user_id",
        "itemsPath": "items",
        "responseType": "getAolUsrRoleLovUserNameResponse",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "user_name"
          ]
        },
        "fetchChain": "getAol_usrRoleLovUserNameFetch"
      }
    },
    "userPayload": {
      "type": "user"
    },
    "userSearch": {
      "type": "usertypesearch",
      "defaultValue": {
        "IN_LIMIT": 8,
        "IN_OFFSET": 0,
        "ROLE_CODE": ""
      }
    },
    "filterCriterion": {
      "type": "any",
      "onValueChanged": {
        "chains": [
          {
            "parameters": {
              "event": "{{ $event }}"
            },
            "chain": "filterCriterionListener"
          }
        ]
      }
    },
    "searchContext": {
      "type": "object",
      "defaultValue": {
        "$search": {
          "filters": {
            "UserNameFilter": {
              "label": "User Name",
              "options": {
                "optionsData": "[[ $page.variables.getAolUsrRoleLovUserNameListSDP ]]",
                "optionsKeys": {
                  "label": "user_name",
                  "value": "user_id"
                }
              }
            },
            "EndDateRangeFilter": {
              "label": "Date "
            }
          }
        }
      }
    },
    "searchConfiguration": {
      "type": "oj-sp/smart-search/strategies/JsonSearchConfigProviderFactory",
      "defaultValue": {
        "url": "[[ $application.path + 'resources/data/userSearchConfig.json' ]]"
      }
    },
    "userAccessADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "user",
        "keyAttributes": "user_id"
      }
    },
    "getEmailListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "endpoint": "UserAccessService/getEmailList",
        "keyAttributes": "email",
        "itemsPath": "items",
        "responseType": "getEmailListResponse",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "email"
          ]
        }
      }
    },
    "getUserNameListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "endpoint": "UserAccessService/getUserNameList",
        "keyAttributes": "user_name",
        "itemsPath": "items",
        "responseType": "getUserNameListResponse",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "user_name"
          ]
        }
      }
    },
    "pagingButton": {
      "type": {
          "next": "boolean",
          "previous": "boolean"
        },
      "defaultValue": {
        "previous": true,
        "next": true
      }
    }
  },
  "metadata": {},
  "types": {
    "@decorators.getAolUsrRoleLovUserNameResponse": {
      "endpoint": "getAol_usrRoleLovUserName",
      "service": "User",
      "path": "response"
    },
    "getAolUsrRoleLovUserNameResponse": {
      "items": [
        {
          "user_id": "number",
          "user_name": "string"
        }
      ]
    },
  "user": {
    "user_id": "number",
    "user_name": "string",
    "user_guid": "string",
    "business_group_id": "number",
    "active_flag": "string",
    "start_date": "string",
    "end_date": "string",
    "person_id": "number",
    "email_address": "string",
    "trx_source": "string",
    "source_rowid": "string",
    "created_by": "string",
    "created_date": "string",
    "last_updated_by": "string",
    "last_updated_date": "string",
    "last_updated_login": "string"
  },
    "usertypesearch": {
      "IN_LIMIT": "number",
      "IN_OFFSET": "number",
      "KEYWORD": "string",
      "P_USER_ACCESS_ID": "number",
      "ROLE_ID": "number",
      "USER_ID": "number",
      "ROLE_CODE": "string",
      "APPLICATION_ID": "number",
      "ACTIVE_FLAG": "string",
      "EFFECTIVE_START_DATE": "string",
      "EFFECTIVE_END_DATE": "string"

    },
    "@decorators.getEmailListResponse": {
      "endpoint": "getEmailList",
      "service": "UserAccessService",
      "path": "response"
    },
    "@decorators.getUserNameListResponse": {
      "endpoint": "getUserNameList", 
      "service": "UserAccessService",
      "path": "response"
    },
    "getEmailListResponse": {
      "items": [
        {
          "email": "string"
        }
      ]
    },
    "getUserNameListResponse": {
      "items": [
        {
          "user_name": "string"
        }
      ]
    }

  },
  "eventListeners": {
    "iconClick": {
      "chains": [
        {
          "chain": "deleteDialogOpenAC",
          "parameters": {
            "event": "{{$event}}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "iconClick2": {
      "chains": [
        {
          "chain": "editIconAC",
          "parameters": {
            "event": "{{$event}}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "nxtBtnAction": {
      "chains": [
        {
          "chain": "nextAC",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "preBtnAction": {
      "chains": [
        {
          "chain": "previousAC",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "refreshBtnAction": {
      "chains": [
        {
          "chain": "refreshAC",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "resetBtnAction": {
      "chains": [
        {
          "chain": "resetAC",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "vbEnter": {
      "chains": [
        {
          "parameters": {},
          "chain": "vbEnterListener"
        }
      ]
    }

  },
  "imports": {
    "components": {
      "oj-button": {
        "path": "ojs/ojbutton"
      },
      "oj-input-date": {
        "path": "ojs/ojdatetimepicker"
      },
      "oj-bind-text": {
        "path": "ojs/ojbindtext"
      },
      "oj-bind-if": {
        "path": "ojs/ojbindif"
      },
      "oj-sp-smart-search": {
        "path": "oj-sp/smart-search/loader"
      },
      "oj-sp-smart-search-page": {
        "path": "oj-sp/smart-search-page/loader"
      },
      "oj-table": {
        "path": "ojs/ojtable"
      },
      "oj-toolbar": {
        "path": "ojs/ojtoolbar"
      }

    },
    "modules": {
      "ojValidationDateTime": {
        "path": "ojs/ojvalidation-datetime"
      }
    },
    "css": [
      "/resources/css/smartSearch.css"
    ]
  },
  "constants": {
    "tableColumns": {
      "type": "object[]",
      "defaultValue": [
          {
            "headerText": "User Name",
            "field": "user_name",
            "resizable": "enabled",
            "template": "user_name_template",
            "headerStyle": "white-space: normal;",
            "style": ""
          },
          {
            "headerText": "Person ID",
            "field": "person_id",
            "resizable": "enabled",
            "width": 250,
            "headerStyle": "white-space: normal;",
            "style": ""
          },
          {
            "headerText": "Effective Start Date",
            "field": "start_date",
            "resizable": "enabled",
            "width": 170,
            "template": "date_template",
            "headerStyle": "white-space: normal;",
            "style": ""
          },
          {
            "headerText": "Effective End Date",
            "field": "end_date",
            "resizable": "enabled",
            "width": 170,
            "template": "date_template",
            "headerStyle": "white-space: normal;",
            "style": ""
          },
          {
            "headerText": "Status",
            "field": "active_flag",
            "resizable": "enabled",
            "width": 120,
            "template": "active_flag_icon",
            "headerStyle": "white-space: normal;",
            "style": ""
          }
        ]    },
    "tableColumnWithActions": {
      "type": "object[]",
      "defaultValue": "[[ [\n    {\n        \"headerText\": \"Actions\",\n        \"field\": \"\",\n        \"resizable\": \"enabled\",\n        \"width\": 78,\n        \"template\": \"actions_template\",\n        \"sortable\": \"disabled\",\n        \"headerStyle\": \"text-align: center; white-space: normal;\",\n        \"style\": \"text-align: center; vertical-align: middle;\"\n    },\n    {\n        \"headerText\": \"User Name\",\n        \"field\": \"user_name\",\n        \"resizable\": \"enabled\",\n        \"template\": \"user_name_template\",\n        \"headerStyle\": \"white-space: normal;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"Email\",\n        \"field\": \"email_address\",\n        \"resizable\": \"enabled\",\n        \"width\": 400,\n        \"headerStyle\": \"white-space: normal;\",\n        \"style\": \"\",\n        \"width\": 400\n    },\n    {\n        \"headerText\": \"Effective Start Date\",\n        \"field\": \"start_date\",\n        \"resizable\": \"enabled\",\n        \"width\": 200,\n        \"template\": \"date_template\",\n        \"headerStyle\": \"white-space: normal;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"Effective End Date\",\n        \"field\": \"end_date\",\n        \"resizable\": \"enabled\",\n        \"width\": 200,\n        \"template\": \"date_template\",\n        \"headerStyle\": \"white-space: normal;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"Status\",\n        \"field\": \"active_flag\",\n        \"resizable\": \"enabled\",\n        \"width\": 70,\n        \"sortable\": \"disabled\",\n        \"template\": \"active_flag_icon\",\n        \"headerStyle\": \"text-align: center; white-space: normal; min-width: 100px;\",\n        \"style\": \"text-align: center; vertical-align: middle;\"\n    }\n] ]]"    }
  }
}