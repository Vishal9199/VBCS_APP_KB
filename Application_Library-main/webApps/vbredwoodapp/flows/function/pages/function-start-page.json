{
  "title": "Function Management",
  "description": "Smart Search page for Function Management with search parameters: Function Code and Function Name",
  "variables": {
    "getApplicationLovAppCodeListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "endpoint": "Application/getApplicationLovAppCode",
        "keyAttributes": "application_name",
        "itemsPath": "items",
        "responseType": "getApplicationLovAppCodeResponse2",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "application_name"
          ]
        }
      }
    },
    "getApplicationLovAppCodeListSDP2": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "keyAttributes": "application_id",
        "itemsPath": "items",
        "responseType": "getApplicationLovAppCodeResponse3",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "application_name"
          ]
        },
        "fetchChain": "getApplicationLovAppCodeFetch2"
      }
    },
    "getFunctionLovFunctionNameListSDP2": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "keyAttributes": "function_name",
        "itemsPath": "items",
        "responseType": "getFunctionLovFunctionNameResponse2",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "function_name"
          ]
        },
        "fetchChain": "getFunctionLovFunctionNameFetch"
      }
    },
    "getMenuLovMenuNameListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "endpoint": "Menu/getMenuLovMenuName",
        "keyAttributes": "menu_id",
        "itemsPath": "items",
        "responseType": "getMenuLovMenuNameResponse",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "menu_name"
          ]
        }
      }
    },
    "encryptPayload": {
      "type": {
        "payload": "string"
      }
    },
    "filterCriterion": {
      "type": "any",
      "onValueChanged": {
        "chains": [
          {
            "parameters": {
              "event": "{{ $event }}"
            },
            "chain": "filterCriterionAC"
          }
        ]
      }
    },
    "pagingButton": {
      "type": {
        "next": "boolean",
        "previous": "boolean"
      },
      "defaultValue": {
        "next": true,
        "previous": true
      }
    },
    "searchObj": {
      "type": "SearchParametersType",
      "defaultValue": {
        "IN_LIMIT": 8,
        "IN_OFFSET": 0,
        "P_FUNCTION_ID": "",
        "FUNCTION_CODE": "",
        "FUNCTION_NAME": "",
        "ACTIVE_FLAG": "",
        "APPLICATION_ID": "",
        "APPLICATION_CODE": "",
        "PAGE_URL": ""
      }
    },
    "functionManagementADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "FunctionType",
        "keyAttributes": "function_id",
        "data": []
      }
    },
    "searchContext": {
      "type": "object",
      "defaultValue": {
        "$search": {
          "filters": {
            "ApplicationNameFilter": {
              "label": "Application Name",
              "options": {
                "optionsData": "[[ $page.variables.getApplicationLovAppCodeListSDP2 ]]",
                "optionsKeys": {
                  "label": "application_name",
                  "value": "application_id"
                }
              }
            },
            "FunctionNameFilter": {
              "label": "Function Name", 
              "options": {
                "optionsData": "[[ $page.variables.getFunctionLovFunctionNameListSDP2 ]]",
                "optionsKeys": {
                  "label": "function_name", 
                  "value": "function_name"
                }
              }
            }
          }
        }
      }
    },
    "searchConfiguration": {
      "type": "oj-sp/smart-search/strategies/JsonSearchConfigProviderFactory",
      "defaultValue": {
        "url": "[[ $application.path + 'resources/data/functionSearchConfig.json' ]]"
      }
    }
   

  },
  "metadata": {},
  "types": {
    "@decorators.getApplicationLovAppCodeResponse": {
      "endpoint": "getApplicationLovAppCode",
      "service": "Application",
      "path": "response"
    },
    "@decorators.getApplicationLovAppCodeResponse2": {
      "endpoint": "getApplicationLovAppCode",
      "service": "Application",
      "path": "response"
    },
    "@decorators.getApplicationLovAppCodeResponse3": {
      "endpoint": "getApplicationLovAppCode",
      "service": "Application",
      "path": "response"
    },
    "@decorators.getFunctionLovFunctionNameResponse2": {
      "endpoint": "getFunctionLovFunctionName",
      "service": "Function",
      "path": "response"
    },
    "@decorators.getMenuLovMenuNameResponse": {
      "endpoint": "getMenuLovMenuName",
      "service": "Menu",
      "path": "response"
    },
    "FunctionType": {
      "application_code": "string",
      "application_name": "string",
      "created_date": "string",
      "function_id": "string",
      "last_updated_date": "string",
      "last_updated_login": "string",
      "object_version_num": "number",
      "function_code": "string",
      "function_name": "string",
      "remarks": "string",
      "page_url": "string",
      "parameter_json": "string",
      "application_id": "number",
      "active_flag": "string",
      "attribute_json": "string",
      "created_by": "string",
      "last_updated_by": "string"

    },
    "getApplicationLovAppCodeResponse": {
      "items": [
        {
          "application_name": "string"
        }
      ]
    },
    "getApplicationLovAppCodeResponse2": {
      "items": [
        {
          "application_name": "string"
        }
      ]
    },
    "getApplicationLovAppCodeResponse3": {
      "items": [
        {
          "application_id": "number",
          "application_name": "string"
        }
      ]
    },
    "getFunctionLovFunctionNameResponse2": {
      "items": [
        {
          "function_name": "string"
        }
      ]
    },
    "getMenuLovMenuNameResponse": {
      "items": [
        {
          "menu_id": "number",
          "menu_name": "string"
        }
      ]
    },
    "SearchParametersType": {

      "IN_LIMIT": "number",
      "IN_OFFSET": "number",
      "KEYWORD": "string",
      "P_FUNCTION_ID": "string",
      "FUNCTION_CODE": "string",
      "FUNCTION_NAME": "string",
      "ACTIVE_FLAG": "string",
      "APPLICATION_ID": "string",
      "APPLICATION_CODE": "string",
      "PAGE_URL": "string"

    }

  },
  "eventListeners": {
    "addBtnAction": {
      "chains": [
        {
          "chain": "addAC"
        }
      ]
    },
    "deleteBtnNoAction": {
      "chains": [
        {
          "chain": "dialogCloseAC"
        }
      ]
    },
    "deleteBtnYesAction": {
      "chains": [
        {
          "chain": "deleteButtonYesAC"
        }
      ]
    },
    "hyperlinkClick": {
      "chains": [
        {
          "chain": "navigateToApplicationPage",
          "parameters": {
            "event": "{{$event}}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"

          }
        }
      ]
    },
    "iconClick": {
      "chains": [
        {
          "chain": "dialogOpenAC",
          "parameters": {
            "current": "{{ $current }}",
            "index": "{{ $current.index }}",
            "key": "{{ $current.key }}"
          }
        }
      ]
    },
    "iconClick2": {
      "chains": [
        {
          "chain": "nextPageAC"
        }
      ]
    },
    "iconClick3": {
      "chains": [
        {
          "chain": "editDataAC",
          "parameters": {
            "current": "{{$current}}",
            "index": "{{ $current.index }}",
            "key": "{{ $current.key }}"
          }
        }
      ]
    },
    "nextBtnAction": {
      "chains": [
        {
          "chain": "nextPageAC"
        }
      ]
    },
    "prevBtnAction": {
      "chains": [
        {
          "chain": "previousPageAC"
        }
      ]
    },
    "refreshBtnAction": {
      "chains": [
        {
          "chain": "onLoadAC"
        }
      ]
    },
    "resetBtnAction": {
      "chains": [
        {
          "chain": "resetButtonAC"
        }
      ]
    },
    "vbEnter": {
      "chains": [
        {
          "parameters": {},
          "chain": "onLoadAC"
        }
      ]
    }

  },
  "imports": {
    "components": {
      "oj-button": {
        "path": "ojs/ojbutton"
      },
      "oj-dialog": {
        "path": "ojs/ojdialog"
      },
      "oj-input-date": {
        "path": "ojs/ojdatetimepicker"
      },
      "oj-input-text": {
        "path": "ojs/ojinputtext"
      },
      "oj-select-single": {
        "path": "ojs/ojselectsingle"
      },
      "oj-sp-smart-search": {
        "path": "oj-sp/smart-search/loader"
      },
      "oj-sp-smart-search-page": {
        "path": "oj-sp/smart-search-page/loader"
      },
      "oj-table": {
        "path": "ojs/ojtable"
      },
      "oj-bind-text": {
        "path": "ojs/ojbindtext"
      },
      "oj-bind-if": {
        "path": "ojs/ojbindif"
      },
      "oj-toolbar": {
        "path": "ojs/ojtoolbar"
      }

    },
    "modules": {
      "ojValidationDateTime": {
        "path": "ojs/ojvalidation-datetime"
      }
    },
    "css": [
      "/resources/css/smartSearch.css"
    ]
  },
  "constants": {
    "tableColumns": {
      "type": "object[]",
      "defaultValue": "[[ [\n    {\n        \"headerText\": \"Function Code\",\n        \"field\": \"function_code\",\n        \"resizable\": \"enabled\",\n        \"sortable\": \"enabled\",\n        \"headerStyle\": \"white-space: normal;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"Application Name\",\n        \"field\": \"application_name\",\n        \"resizable\": \"enabled\",\n        \"sortable\": \"enabled\",\n        \"headerStyle\": \"white-space: normal;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"Function Name\",\n        \"field\": \"function_name\",\n        \"resizable\": \"enabled\",\n        \"sortable\": \"enabled\",\n        \"template\": \"function_name\",\n        \"headerStyle\": \"white-space: normal;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"Remarks\",\n        \"field\": \"remarks\",\n        \"resizable\": \"enabled\",\n        \"template\": \"remarks\",\n        \"headerStyle\": \"white-space: normal;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"Page URL\",\n        \"field\": \"page_url\",\n        \"resizable\": \"enabled\",\n        \"template\": \"page_url\",\n        \"headerStyle\": \"white-space: normal;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"Active Status\",\n        \"field\": \"active_flag\",\n        \"resizable\": \"enabled\",\n        \"template\": \"active_flag_icon\",\n        \"headerStyle\": \"white-space: normal;\",\n        \"style\": \"\"\n    }\n] ]]"    },
    "tableColumnsWithActions": {
      "type": "object[]",
      "defaultValue": "[[ [\n    {\n        \"headerText\": \"Actions\",\n        \"field\": \"\",\n        \"resizable\": \"enabled\",\n        \"width\": 100,\n        \"template\": \"actions_template\",\n        \"sortable\": \"disabled\",\n        \"headerStyle\": \"text-align: center; white-space: normal;\",\n        \"style\": \"text-align: center; vertical-align: middle;\"\n    },\n    {\n        \"headerText\": \"Function Code\",\n        \"field\": \"function_code\",\n        \"resizable\": \"enabled\",\n        \"sortable\": \"enabled\",\n        \"headerStyle\": \"white-space: normal;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"Function Name\",\n        \"field\": \"function_name\",\n        \"resizable\": \"enabled\",\n        \"sortable\": \"enabled\",\n        \"template\": \"function_name\",\n        \"headerStyle\": \"white-space: normal;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"Application Name\",\n        \"field\": \"application_name\",\n        \"resizable\": \"enabled\",\n        \"template\":\"application\",\n        \"sortable\": \"enabled\",\n        \"headerStyle\": \"white-space: normal;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"Remarks\",\n        \"field\": \"remarks\",\n        \"resizable\": \"enabled\",\n        \"template\": \"remarks\",\n        \"headerStyle\": \"white-space: normal;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"Page URL\",\n        \"field\": \"page_url\",\n        \"resizable\": \"enabled\",\n        \"template\": \"page_url\",\n        \"headerStyle\": \"white-space: normal;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"Status\",\n        \"field\": \"active_flag\",\n        \"resizable\": \"enabled\",\n        \"template\": \"active_flag_icon\",\n        \"headerStyle\": \"white-space: normal;\",\n        \"style\": \"\"\n    }\n] ]]"}
  }
}