{
  "title": "Lov",
  "description": "",
  "variables": {
    "encryptedBody": {
      "type": {
        "payload": "string"
      }
    },
    "lovTypeADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "data": "{{ $constants.lovTypeArray }}",
        "keyAttributes": "value"
      }
    },
    "filterCriterion": {
      "type": "any",
      "onValueChanged": {
        "chains": [
          {
            "parameters": {
              "event": "{{ $event }}"
            },
            "chain": "filterCriterionListener"
          }
        ]
      }
    },
    "getProgramLovcodeListListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "keyAttributes": "lov_config_id",
        "itemsPath": "items",
        "responseType": "getProgramLovcodeListResponse",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "lov_name"
          ]
        },
        "fetchChain": "getProgramLovcodeListFetch"
      }
    },
    "pagination": {
      "type": {
        "next": "boolean",
        "prev": "boolean"
      },
      "defaultValue": {
        "next": false,
        "prev": false
      }
    },
    "searchContext": {
      "type": "object",
      "defaultValue": {
        "$search": {
          "filters": {
            "LovFilter": {
              "label": "LOV Name",
              "options": {
                "optionsData": "[[ $page.variables.getProgramLovcodeListListSDP ]]",
                "optionsKeys": {
                  "label": "lov_name",
                  "value": "lov_config_id"
                }
              }
            },
            "LovTypeFilter": {
              "label": "LOV Type",
              "options": {
                "optionsData": "[[ $page.variables.lovTypeADP ]]",
                "optionsKeys": {
                  "label": "label",
                  "value": "value"
                }
              }
            }
          }
        }
      }
    },
    "searchConfiguration": {
      "type": "oj-sp/smart-search/strategies/JsonSearchConfigProviderFactory",
      "defaultValue": {
        "url": "[[ $application.path + 'resources/data/lovSearchConfig.json' ]]"
      }
    },
    "searchObj": {
      "type": {
        "in_limit": "number",
        "in_offset": "number",
        "p_keyword": "string",
        "p_lov_config_id": "string",
        "p_lov_type": "string",
        "p_active_flag": "string"
      },
      "defaultValue": {
        "in_limit": 3,
        "in_offset": 0,
        "p_keyword": "",
        "p_lov_config_id": "",
        "p_lov_type": "",
        "p_active_flag": ""
      }
    },
    "lovConfigurationADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "LovConfigurationType",
        "keyAttributes": "lov_config_id"
      }
    }
  },
  "metadata": {},
  "types": {
    "@decorators.getLovConfigIdLovResponse": {
      "endpoint": "getLovConfigIdLov",
      "service": "LovConfiguration",
      "path": "response"
    },
    "@decorators.getLovTypeLovResponse": {
      "endpoint": "getLovTypeLov",
      "service": "LovConfiguration",
      "path": "response"
    },
    "@decorators.getActiveFlagLovResponse": {
      "endpoint": "getActiveFlagLov",
      "service": "LovConfiguration",
      "path": "response"
    },
    "@decorators.getProgramLovcodeListResponse": {
      "endpoint": "getProgramLovcodeList",
      "service": "Program",
      "path": "response"
    },
    "@decorators.getProgramLovtypeListResponse": {
      "endpoint": "getProgramLovtypeList",
      "service": "Program",
      "path": "response"
    },
    "getProgramLovcodeListResponse": {
      "items": [
        {
          "lov_code": "string",
          "lov_config_id": "number",
          "lov_name": "string"
        }
      ]
    },
    "getProgramLovtypeListResponse": {
      "items": [
        {
          "lov_type": "string"
        }
      ]
    },
    "LovConfigurationType": {
      "lov_config_id": "number",
      "object_version_num": "number",
      "lov_code": "string",
      "lov_name": "string",
      "lov_description": "string",
      "lov_type": "string",
      "lov_type_display": "string",
      "query_text": "string",
      "bind_parameters": "string",
      "return_value_column": "string",
      "display_column": "string",
      "description_column": "string",
      "order_by_clause": "string",
      "active_flag": "string",
      "active_status": "string",
      "created_by": "string",
      "created_date": "string",
      "last_updated_by": "string",
      "last_updated_date": "string",
      "last_updated_login": "string",
      "created_date_display": "string",
      "last_updated_date_display": "string",
      "parameter_usage_count": "number",
      "search_text": "string"
    },
    "getLovConfigIdLovResponse": {
      "items": [
        {
          "lov_config_id": "number",
          "lov_name": "string"
        }
      ]
    },
    "getLovTypeLovResponse": {
      "items": [
        {
          "lov_type": "string",
          "lov_type_display": "string"
        }
      ]
    },
    "getActiveFlagLovResponse": {
      "items": [
        {
          "active_flag": "string",
          "active_status": "string"
        }
      ]
    }
  },
  "chains": {},
  "eventListeners": {
    "addBtnAction": {
      "chains": [
        {
          "chain": "addBtnAC"
        }
      ]
    },
    "deleteBtnAction": {
      "chains": [
        {
          "chain": "deleteActionAC",
          "parameters": {
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "deleteBtnNoAction": {
      "chains": [
        {
          "chain": "noDeleteAC"
        }
      ]
    },
    "deleteBtnYesAction": {
      "chains": [
        {
          "chain": "okDeleteAC"
        }
      ]
    },
    "hyperlinkClick": {
      "chains": [
        {
          "chain": "editAC",
          "parameters": {
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "iconClick": {
      "chains": [
        {
          "chain": "deleteActionAC",
          "parameters": {
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "iconClick2": {
      "chains": [
        {
          "chain": "editAC",
          "parameters": {
            "event": "{{$event}}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "nxtBtnAction": {
      "chains": [
        {
          "chain": "nextBtnAC"
        }
      ]
    },
    "preBtnAction": {
      "chains": [
        {
          "chain": "prevBtnAC"
        }
      ]
    },
    "refreshBtnAction": {
      "chains": [
        {
          "chain": "refreshBtn",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "resetBtnAction": {
      "chains": [
        {
          "chain": "resetAC"
        }
      ]
    },
    "vbEnter": {
      "chains": [
        {
          "chain": "PageVbEnterChain"
        }
      ]
    }
  },
  "imports": {
    "components": {
      "oj-button": {
        "path": "ojs/ojbutton"
      },
      "oj-dialog": {
        "path": "ojs/ojdialog"
      },
      "oj-input-text": {
        "path": "ojs/ojinputtext"
      },
      "oj-label": {
        "path": "ojs/ojlabel"
      },
      "oj-select-single": {
        "path": "ojs/ojselectsingle"
      },
      "oj-sp-smart-search": {
        "path": "oj-sp/smart-search/loader"
      },
      "oj-sp-smart-search-page": {
        "path": "oj-sp/smart-search-page/loader"
      },
      "oj-table": {
        "path": "ojs/ojtable"
      },
      "oj-toolbar": {
        "path": "ojs/ojtoolbar"
      }
    },
    "modules": {
      "ojValidationDateTime": {
        "path": "ojs/ojvalidation-datetime"
      }
    },
    "css": [
      "/resources/css/smartSearch.css"
    ]
  },
  "constants": {
    "tableColumns": {
      "type": "object[]",
      "defaultValue": [
        {
          "headerText": "LOV Code",
          "field": "lov_code",
          "resizable": "enabled",
          "width": 250,
          "sortable": "enabled",
          "template": "lov_code",
          "headerStyle": "white-space: normal; min-width: 180px;",
          "style": ""
        },
        {
          "headerText": "LOV Name",
          "field": "lov_name",
          "resizable": "enabled",
          "width": 250,
          "sortable": "enabled",
          "template": "lov_name",
          "headerStyle": "white-space: normal; min-width: 220px;",
          "style": ""
        },
        {
          "headerText": "LOV Type",
          "field": "lov_type",
          "resizable": "enabled",
          "width": 250,
          "sortable": "enabled",
          "template": "lov_type_display",
          "headerStyle": "white-space: normal; min-width: 150px;",
          "style": ""
        },
        {
          "headerText": "Status",
          "field": "active_flag",
          "resizable": "enabled",
          "width": 100,
          "sortable": "disabled",
          "template": "active_flag",
          "headerStyle": "text-align: center; white-space: normal; min-width: 100px;",
          "style": "text-align: center; vertical-align: middle;"
        },
        {
          "headerText": "Description",
          "field": "lov_description",
          "resizable": "enabled",
          "template": "lov_description",
          "headerStyle": "white-space: normal; min-width: 250px;",
          "style": ""
        }
      ]
    },
    "tableColumnsWithActions": {
      "defaultValue": [
        {
          "headerText": "Actions",
          "field": "",
          "resizable": "enabled",
          "width": 100,
          "template": "actions",
          "sortable": "disabled",
          "headerStyle": "text-align: center; white-space: normal;",
          "style": "text-align: center; vertical-align: middle;"
        },
        {
          "headerText": "LOV Code",
          "field": "lov_code",
          "resizable": "enabled",
          "width": 250,
          "sortable": "enabled",
          "template": "lov_code",
          "headerStyle": "white-space: normal; min-width: 180px;",
          "style": ""
        },
        {
          "headerText": "LOV Name",
          "field": "lov_name",
          "resizable": "enabled",
          "width": 250,
          "sortable": "enabled",
          "template": "lov_name",
          "headerStyle": "white-space: normal; min-width: 220px;",
          "style": ""
        },
        {
          "headerText": "LOV Type",
          "field": "lov_type",
          "resizable": "enabled",
          "width": 250,
          "sortable": "enabled",
          "template": "lov_type_display",
          "headerStyle": "white-space: normal; min-width: 150px;",
          "style": ""
        },
        {
          "headerText": "Status",
          "field": "active_flag",
          "resizable": "enabled",
          "width": 100,
          "sortable": "disabled",
          "template": "active_flag",
          "headerStyle": "text-align: center; white-space: normal; min-width: 100px;",
          "style": "text-align: center; vertical-align: middle;"
        },
        {
          "headerText": "Description",
          "field": "lov_description",
          "resizable": "enabled",
          "template": "lov_description",
          "headerStyle": "white-space: normal; min-width: 250px;",
          "style": ""
        }
      ],
      "type": "object[]"
    },
    "lovTypeArray": {
      "type": "object[]",
      "defaultValue": [
        {
          "label": "DIRECT",
          "value": "DIRECT"
        },
        {
          "label": "DEPENDENT",
          "value": "DEPENDENT"
        },
        {
          "label": "STATIC",
          "value": "STATIC"
        }
      ]
    }
  }
}