{
  "title": "",
  "description": "",
  "variables": {
    "adpAttachmentFile": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "postAttachmentSearch",
        "keyAttributes": "document_id"
      }
    },
    "adpAttachmentText": {
      "defaultValue": {
        "itemType": "postAttachmentSearch",
        "keyAttributes": "document_id"
      },
      "type": "vb/ArrayDataProvider2"
    },
    "adpAttachmentUrl": {
      "defaultValue": {
        "itemType": "postAttachmentSearch",
        "keyAttributes": "document_id"
      },
      "type": "vb/ArrayDataProvider2"
    },
    "attachmentObj": {
      "type": {
        "P_DOCUMENT_NAME": "string",
        "P_DOCUMENT_CATEGORY": "string",
        "P_DOCUMENT_TYPE": "string",
        "P_DOCUMENT_FILE": "any",
        "P_DESCRIPTION": "string",
        "P_APPL_CODE": "string",
        "P_TRANSACTION_ID": "string",
        "P_TYPE": "string",
        "P_TITLE": "string",
        "P_URL": "string",
        "P_CREATED_BY": "string"
      },
      "defaultValue": {
        "P_APPL_CODE": "[[ $variables.P_APPLICATION_CODE ]]",
        "P_CREATED_BY": "[[ $application.user.email ]]",
        "P_TRANSACTION_ID": "[[ $variables.P_TRANSACTION_ID ]]",
        "P_TYPE": "FILE",
        "P_DOCUMENT_CATEGORY": "TENDER_STRATEGY",
        "P_TITLE": "Tender Strategy",
        "P_DESCRIPTION": "Tender Strategy Attachment",
        "P_URL": "0"
      }
    },
    "formObj": {
      "type": {
        "addDialogValidate": "string"
      }
    },
    "P_APPLICATION_CODE": {
      "type": "string",
      "input": "fromCaller",
      "required": false
    },
    "P_SCREEN_NAME": {
      "type": "string",
      "input": "fromCaller"
    },
    "P_STATUS": {
      "type": "string",
      "input": "fromCaller"
    },
    "P_TRANSACTION_ID": {
      "type": "string",
      "@dt": {
        "label": "P_TRANSACTION_ID"
      },
      "input": "fromCaller"
    },
    "P_TRANSACTION_NUMBER": {
      "type": "string",
      "description": "REQ-1002",
      "input": "fromCaller"
    },
    "rowId": {
      "type": "string"
    },
    "rowTransId": {
      "type": "string"
    },
    "selectedTab": {
      "type": "string",
      "defaultValue": "file-tab"
    }
  },
  "metadata": {
    "dynamicContainerMetadata": {
      "type": "vb/ContainerMetadataProviderDescriptor"
    }
  },
  "types": {
    "@decorators.postAttachmentSearch": {
      "endpoint": "postAttachmentSearch",
      "service": "ORDS",
      "path": "response"
    },
    "postAttachmentSearch": {
      "additional_info": "any",
      "appl_code": "string",
      "created_by": "string",
      "created_date": "string",
      "description": "string",
      "document_category": "string",
      "document_id": "number",
      "document_name": "string",
      "document_type": "string",
      "last_updated_by": "string",
      "last_updated_date": "string",
      "last_updated_login": "string",
      "reference_id": "number",
      "title": "string",
      "transaction_id": "number",
      "type": "string",
      "url": "any"
    }
  },
  "eventListeners": {
    "downloadAction": {
      "chains": [
        {
          "chain": "onClickDownload",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },

    "vbEnter": {
      "chains": [
        {
          "parameters": {},
          "chain": "vbEnterListener"
        }
      ]
    },
    "addFileBtnAction": {
      "chains": [
        {
          "chain": "onAddAttachment",
          "parameters": {
            "btnType": "FILE"
          }
        }
      ]
    },
    "addRefFileBtnAction": {
      "chains": [
        {
          "chain": "onRefresh"
        }
      ]
    },
    "attachmentFilePickerSelect": {
      "chains": [
        {
          "chain": "FilePickerSelectChain",
          "parameters": {

            "files": "[[ Array.prototype.slice.call($event.detail.files) ]]"
          }
        }
      ]
    },
    "attachmentSaveCloseAction": {
      "chains": [
        {
          "chain": "onClickCancel",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "attachmentSaveCloseAction2": {
      "chains": [
        {
          "chain": "onClickSave",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "cancelDeleteBtnAction": {
      "chains": [
        {
          "chain": "onDilaogCancel"
        }
      ]
    },
    "confirmDeleteBtnAction": {
      "chains": [
{
          "chain": "onDeleteOk",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "ojAttachmentSpCancel": {
      "chains": [
        {
          "chain": "AdvancedCreateAndEditPageTemplateSpCancelChain",
          "parameters": {
            "event": "{{$event}}"
          }
        }
      ]
    }

  },
  "imports": {
    "components": {
      "oj-button": {
        "path": "ojs/ojbutton"
      },
      "oj-dialog": {
        "path": "ojs/ojdialog"
      },
      "oj-file-picker": {
        "path": "ojs/ojfilepicker"
      },
      "oj-form-layout": {
        "path": "ojs/ojformlayout"
      },
      "oj-input-text": {
        "path": "ojs/ojinputtext"
      },
      "oj-option": {
        "path": "ojs/ojoption"
      },
      "oj-progress-circle": {
        "path": "ojs/ojprogress-circle"
      },
      "oj-radioset": {
        "path": "ojs/ojradioset"
      },
      "oj-sp-advanced-create-edit": {
        "path": "oj-sp/advanced-create-edit/loader"
      },
      "oj-sp-message-unsaved-changes": {
        "path": "oj-sp/message-unsaved-changes/loader"
      },
      "oj-sp-vertical-anchor-navigator": {
        "path": "oj-sp/vertical-anchor-navigator/loader"
      },
      "oj-table": {
        "path": "ojs/ojtable"
      },
      "oj-validation-group": {
        "path": "ojs/ojvalidationgroup"
      }
    },
    "css": [
      "/resources/css/redwood-overrides.css"
    ]
  },
