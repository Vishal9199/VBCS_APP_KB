              "template1": "template1",
              "template2": "template2"
            },
            "displayProperties": [
              "template1",
              "template2"
            ]
          }
        }
      },
      "rules": [
        "containerLayout1-rule1"
      ]
    },
    "containerLayout1-rule1": {
      "expression": "case1"
    }
  },
  "templates": {
    "template1": {
      "title": "Section 1",
