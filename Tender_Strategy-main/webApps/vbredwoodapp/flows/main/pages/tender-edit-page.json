  "eventListeners": {
    "apprResponseBtnAction": {
      "chains": [
        {
          "chain": "onClick_ApproverMoreInfo_AC",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "attachmentFilePickerSelect": {
      "chains": [
        {
          "chain": "FilePickerSelectChain1",
          "parameters": {
            "event": "{{$event}}",
            "files": "[[ Array.prototype.slice.call($event.detail.files) ]]",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "buttonAction": {
      "chains": [
        {
          "chain": "confirmCancel_Dialog_AC",
