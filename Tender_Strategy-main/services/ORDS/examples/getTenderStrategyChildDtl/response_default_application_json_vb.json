            "strategy_hdr_id": 255,
            "tender_objective": "A tender objective outlines the goal for a procurement, usually to get the best value (quality/price) by attracting qualified suppliers to submit competitive bids for a specific project, ensuring fairness, transparency, and clear requirements like scope, timelines, and evaluation criteria, as seen in samples for construction or IT services. ",
            "tender_background": "A tender background sets the stage for a project or service request, explaining the client's needs, project scope, goals, and why they're seeking bids (e.g., for a new library, IT system), detailing requirements like timelines, budget context, and key challenges, ensuring potential suppliers understand the \"why\" and \"what\" before crafting their formal offers (tenders/bids).",
            "tender_scope_work": "<p>**Risk Assessment is applicable for Projects that its Estimated Value more R.O 100,000/-**</p>\n<figure>\n    <table style=\"border: none; width: 100%;\">\n        <tbody>\n            <tr>\n                <td style=\"color:#D6E3BC;background-color:#D6E3BC;border: 1.0pt solid windowtext;\">\n                    <p style=\"text-align:center;\">Risk</p>\n                </td>\n                <td style=\"color:#D6E3BC;background-color:#D6E3BC;border-left:1.0pt none windowtext;border-right:1.0pt solid windowtext;border-top:1.0pt solid windowtext;border-bottom:1.0pt solid windowtext;\">\n                    <p style=\"text-align:center;\"><span style=\"color:black;\">Impact</span></p>\n                </td>\n                <td style=\"color:#D6E3BC;background-color:#D6E3BC;border-left:1.0pt none windowtext;border-right:1.0pt solid windowtext;border-top:1.0pt solid windowtext;border-bottom:1.0pt solid windowtext;\">\n                    <p style=\"text-align:center;\"><span style=\"color:black;\">Mitigation Strategy</span></p>\n                </td>\n            </tr>\n            <tr>\n                <td style=\"border-left:1.0pt solid windowtext;border-right:1.0pt solid windowtext;border-top:1.0pt none windowtext;border-bottom:1.0pt solid windowtext;\">\n                    <p style=\"text-align:justify;\">&nbsp;</p>\n                </td>\n                <td style=\"border-left:none;border-right:1.0pt solid windowtext;border-top:none;border-bottom:1.0pt solid windowtext;\">\n                    <p style=\"text-align:justify;\">&nbsp;</p>\n                </td>\n                <td style=\"border-left:none;border-right:1.0pt solid windowtext;border-top:none;border-bottom:1.0pt solid windowtext;\">\n                    <p style=\"text-align:justify;\">&nbsp;</p>\n                </td>\n            </tr>\n            <tr>\n                <td style=\"border-left:1.0pt solid windowtext;border-right:1.0pt solid windowtext;border-top:1.0pt none windowtext;border-bottom:1.0pt solid windowtext;\">\n                    <p style=\"text-align:justify;\">&nbsp;</p>\n                </td>\n                <td style=\"border-left:none;border-right:1.0pt solid windowtext;border-top:none;border-bottom:1.0pt solid windowtext;\">\n                    <p style=\"text-align:justify;\">&nbsp;</p>\n                </td>\n                <td style=\"border-left:none;border-right:1.0pt solid windowtext;border-top:none;border-bottom:1.0pt solid windowtext;\">\n                    <p style=\"text-align:justify;\">&nbsp;</p>\n                </td>\n            </tr>\n            <tr>\n                <td style=\"border-left:1.0pt solid windowtext;border-right:1.0pt solid windowtext;border-top:1.0pt none windowtext;border-bottom:1.0pt solid windowtext;\">\n                    <p style=\"text-align:justify;\">&nbsp;</p>\n                </td>\n                <td style=\"border-left:none;border-right:1.0pt solid windowtext;border-top:none;border-bottom:1.0pt solid windowtext;\">\n                    <p style=\"text-align:justify;\">&nbsp;</p>\n                </td>\n                <td style=\"border-left:none;border-right:1.0pt solid windowtext;border-top:none;border-bottom:1.0pt solid windowtext;\">\n                    <p style=\"text-align:justify;\">&nbsp;</p>\n                </td>\n            </tr>\n        </tbody>\n    </table>\n</figure>",
            "tender_cost_estimate": "Cost Component",
            "tender_technical_criteria": "<table>\r\n<tbody>\r\n<tr>\r\n<td>\r\n<p><strong>Sr.&nbsp;No.</strong></p>\r\n</td>\r\n<td>\r\n<p><strong>Technical&nbsp;Mandatory&nbsp;Criteria</strong></p>\r\n</td>\r\n<td>\r\n<p><strong>Requirements</strong></p>\r\n</td>\r\n</tr>\r\n<tr>\r\n<td>\r\n<p><strong>1)&nbsp;</strong></p>\r\n</td>\r\n<td>Bidder&nbsp;shall&nbsp;submit&nbsp;ICV&nbsp;commitment&nbsp;letter&nbsp;as&nbsp;per&nbsp;the&nbsp;form&nbsp;provided&nbsp;in&nbsp;APPENDIX&nbsp;D</td>\r\n<td>\r\n<p><strong>Mandatory</strong></p>\r\n</td>\r\n</tr>\r\n<tr>\r\n<td>\r\n<p><strong>2)&nbsp;</strong></p>\r\n</td>\r\n<td>Bidder shall submit unpriced ICV plan in electronic copy (soft copy in MS Excel file and PDF) as per Appendix A, to be submitted along with technical proposal as a separate file.&nbsp;</td>\r\n<td>&nbsp;</td>\r\n</tr>\r\n</tbody>\r\n</table>",
            "tender_commercial_criteria": "<p><strong>1.1.&nbsp;Commercial&nbsp;Evaluation&nbsp;Criteria</strong></p>\n<p><strong><u>ICV&nbsp;Commercial&nbsp;priced&nbsp;Evaluation&nbsp;Requirement</u></strong></p>\n<table>\n<tbody>\n<tr>\n<td>\n<p><strong><u>SN</u></strong></p>\n</td>\n<td>\n<p><strong>Technical&nbsp;Bid&nbsp;Evaluation&nbsp;Criteria</strong></p>\n</td>\n<td>\n<p><strong><u>Requirement</u></strong></p>\n</td>\n</tr>\n<tr>\n<td>\n<p>1.</p>\n</td>\n<td>\n<p><u>If the proposal value is&nbsp;</u><strong><u>more&nbsp;than&nbsp;OMR&nbsp;385,000/-.</u></strong></p>\n<p>Bidder&nbsp;must&nbsp;submit&nbsp;priced&nbsp;ICV&nbsp;plan&nbsp;in&nbsp;electronic\n  copy&nbsp;of&nbsp;the&nbsp;ICV&nbsp;plan&nbsp;(in&nbsp;MS&nbsp;Excel&nbsp;and&nbsp;PDF&nbsp;formats)\n  must&nbsp;be submitted,&nbsp;as&nbsp;per&nbsp;&ndash;&nbsp;Appendix&nbsp;B, a&nbsp;separate&nbsp;file&nbsp;along&nbsp;with&nbsp;the&nbsp;Commercial&nbsp;proposal.</p>\n</td>\n<td>&nbsp;</td>\n</tr>\n</tbody>\n</table>",
            "tender_icv_minimum_info": "<table border=\"1\" cellspacing=\"0\" cellpadding=\"6\">\n   <thead style=\"background-color: #d4e6b5;\">\n      <tr>\n         <th>S.No</th>\n         <th>Category</th>\n         <th>Minimum Requirements</th>\n         <th>Comments / Key Performance Indicator</th>\n      </tr>\n   </thead>\n   <tbody>\n      <tr>\n         <td rowspan=\"5\">1</td>\n         <td>Nationalization per job category:</td>\n         <td rowspan=\"5\"></td>\n         <td rowspan=\"5\"> Headcount of Omani Nationals utilized in the Contract execution in the following categories (Senior Management, Professional, Supervisory and Skilled/Semi Skilled) as % of total headcount for the same categories (including Contractors and Third Party Sub-Contractor). </td>\n      </tr>\n      <tr>\n         <td>Senior Management</td>\n      </tr>\n      <tr>\n         <td>Professional</td>\n      </tr>\n      <tr>\n         <td>Supervisory</td>\n      </tr>\n      <tr>\n         <td>Skilled/Semiskilled</td>\n      </tr>\n      <tr>\n         <td>2</td>\n         <td>Sourcing of Made-in-Oman Goods.</td>\n         <td></td>\n         <td> Expenditure on Made-in-Oman Goods used in execution of Contract sourced from local manufacturer as % of total contract value (including Contractors and Third-Party Sub-Contractor). </td>\n      </tr>\n      <tr>\n         <td>3</td>\n         <td>Sourcing of Non-Made-in-Oman Goods.</td>\n         <td></td>\n         <td> Expenditure on non-Made-in-Oman Goods used in the execution of the Contract, sourced from Nationally-Registered Suppliers as % of total Contract value. </td>\n      </tr>\n      <tr>\n         <td>4</td>\n         <td>Local sourcing of services</td>\n         <td></td>\n         <td> Expenditure on services used in the execution of the Contract, sourced from Nationally-Registered Suppliers as % of total Contract value. </td>\n      </tr>\n      <tr>\n         <td rowspan=\"4\">5</td>\n         <td rowspan=\"4\">Local sourcing of SMEs</td>\n         <td rowspan=\"4\"></td>\n         <td> Expenditure on goods and service used in the execution of the Contract, sourced from SMEs (Riyada card holder), as % of total contract value. </td>\n      </tr>\n      <tr>\n         <td>The SMEs value is part of any of the following: Made-in-Oman Goods</td>\n      </tr>\n      <tr>\n         <td>Non-Made in Oman Goods sourced from Nationally Registered Supplier</td>\n      </tr>\n      <tr>\n         <td>Services sourced from Nationally Registered Supplier</td>\n      </tr>\n      <tr>\n         <td>6</td>\n         <td>Any additional requirements</td>\n         <td></td>\n         <td> Any additional mandatory requirements identified during the strategy (transfer of knowledge, training SMEs, scholarships, transfer of technology etc.) </td>\n      </tr>\n   </tbody>\n</table>",
