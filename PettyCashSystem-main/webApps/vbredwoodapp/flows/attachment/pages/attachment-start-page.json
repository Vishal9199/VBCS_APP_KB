      "chains": [
        {
          "chain": "AdvancedCreateAndEditPageTemplateSpCancelChain",
          "parameters": {
            "event": "{{$event}}"
          }
        }
      ]
    },
    "ojAttachmentSpPrimaryAction": {
      "chains": [
        {
          "chain": "AdvancedCreateAndEditPageTemplateSpPrimaryActionChain",
          "parameters": {
            "event": "{{$event}}"
          }
        }
