            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "attachmentSaveCloseAction2": {
      "chains": [
        {
          "chain": "onClickSave",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "cancelDeleteBtnAction": {
      "chains": [
        {
          "chain": "onDilaogCancel"
        }
      ]
    },
    "confirmDeleteBtnAction": {
      "chains": [
{
          "chain": "onDeleteOk",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "deleteBtnAction": {
      "chains": [
        {
          "chain": "onClickDeleteBtn",
          "parameters": {

            "current": "{{ $current }}",
            "event": "{{ $event }}",
            "index": "{{ $current.index }}",
            "key": "{{ $current.key }}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "deleteBtnAction2": {
      "chains": [
{
          "chain": "onClickDownload",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
