      "type": "object",
      "defaultValue": {
        "$search": {
          "filters": {
            "GovernateFilter": {
              "label": "Governate",
              "options": {
                "optionsData": "[[ $page.variables.governateUserLOV_SDP]]",
                "optionsKeys": {
