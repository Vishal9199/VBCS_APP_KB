  "eventListeners": {
    "addRowBtnAction": {
      "chains": [
        {
          "chain": "addrowactionchain",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "buttonAction": {
      "chains": [
        {
          "chain": "onDeleteAction",
          "parameters": {
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "buttonAction2": {
