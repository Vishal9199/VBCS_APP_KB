{
  "title": "PAM Schedule Details Search",
  "description": "Smart Search page for PAM Schedule Details with inline table editing",
  "variables": {
    "count": {
      "type": "number",
      "defaultValue": 9999999999999
    },
    "currentCount": {
      "type": "number",
      "defaultValue": 0
    },
    "currentOffset": {
      "type": "number",
      "defaultValue": 0
    },
    "currentPage": {
      "type": "number",
      "defaultValue": 1
    },
    "filterCriterion": {
      "type": "any",
      "onValueChanged": {
        "chains": [
          {
            "parameters": {
              "event": "{{ $event }}"
            },
            "chain": "filterCriterionListener"
          }
        ]
      }
    },
    "getPmispamLovUsersListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "keyAttributes": "user_id",
        "itemsPath": "items",
        "responseType": "getPmispamLovUsersResponse",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "person_full_name"
          ]
        },
        "fetchChain": "getPmispamLovUsersFetch"
      }
    },
    "getProjectLovListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "responseType": "getPmispamConceptstudyLovProjectname",
        "itemsPath": "items",
        "keyAttributes": "project_id",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "project_name"
          ]
        },
        "fetchChain": "getPmispamConceptstudyLovProjectnameFetch"
      }
    },
    "getPhaseLovListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "responseType": "getPmispamConceptstudyLovPhase",
        "itemsPath": "items",
        "keyAttributes": "lookup_value_id",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "lookup_value_name"
          ]
        },
        "fetchChain": "getPmispamConceptstudyLovPhaseFetch"
      }
    },
    "getMilestoneLovListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "responseType": "getPmispamConceptstudyLovMilestone",
        "itemsPath": "items",
        "keyAttributes": "lookup_value_id",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "lookup_value_name"
          ]
        },
        "fetchChain": "getPmispamConceptstudyLovMilestoneFetch"
      }
    },
    "getConsultantLovListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "responseType": "getPmispamConceptstudyLovConsultant",
        "itemsPath": "items",
        "keyAttributes": "lookup_value_id",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "lookup_value_name"
          ]
        },
        "fetchChain": "getPmispamConceptstudyLovConsultantFetch"
      }
    },
    "hasNext": {
      "type": "string",
      "defaultValue": "N"
    },
    "pagination": {
      "type": "object",
      "defaultValue": {
        "is_next": false,
        "is_prev": true
      }
    },
    "paginationDisplay": {
      "type": "string",
      "defaultValue": "0 - 0 of 0 items"
    },
    "passKey": {
      "type": "string"
    },
    "passPayload": {
      "type": "string"
    },
    "postpayloadcustom": {
      "type": "postpayloadcustom"
    },
    "rowToEdit": {
      "type": {
        "rowKey": "number"
      }
    },
    "searchContext": {
      "type": "object",
      "defaultValue": {
        "$search": {
          "filters": {
            "ProjectFilter": {
              "label": "Project",
              "options": {
                "optionsData": "[[ $page.variables.getProjectLovListSDP ]]",
                "optionsKeys": {
                  "label": "project_name",
                  "value": "project_id"
                }
              }
            },
            "PhaseFilter": {
              "label": "Phase",
              "options": {
                "optionsData": "[[ $page.variables.getPhaseLovListSDP ]]",
                "optionsKeys": {
                  "label": "lookup_value_name",
                  "value": "lookup_value_name"
                }
              }
            },
            "MilestoneFilter": {
              "label": "Milestone",
              "options": {
                "optionsData": "[[ $page.variables.getMilestoneLovListSDP ]]",
                "optionsKeys": {
                  "label": "lookup_value_name",
                  "value": "lookup_value_name"
                }
              }
            },
            "ConsultantFilter": {
              "label": "Consultant",
              "options": {
                "optionsData": "[[ $page.variables.getConsultantLovListSDP ]]",
                "optionsKeys": {
                  "label": "lookup_value_name",
                  "value": "lookup_value_name"
                }
              }
            },
            "DateRangeFilter": {
              "label": "Date Range"
            }
          }
        }
      }
    },
    "searchConfiguration": {
      "type": "oj-sp/smart-search/strategies/JsonSearchConfigProviderFactory",
      "defaultValue": {
        "url": "[[ $application.path + 'resources/data/pamschedulesearchconfig.json' ]]"
      }
    },
    "searchObj": {
      "type": {
        "in_limit": "string",
        "in_offset": "string",
        "p_consultant_name": "string",
        "p_milestone": "string",
        "p_phase_name": "string",
        "p_planned_end_date": "string",
        "p_planned_start_date": "string",
        "p_project_id": "string",
        "p_project_name": "string",
        "p_keyword": "string"
      },
      "defaultValue": {
        "in_limit": "10",
        "in_offset": "0",
        "p_project_id": "",
        "p_project_name": "",
        "p_phase_name": "",
        "p_milestone": "",
        "p_consultant_name": "",
        "p_planned_start_date": "",
        "p_planned_end_date": "",
        "p_keyword": ""
      }
    },
    "pamScheduleADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "PAMScheduleType",
        "keyAttributes": "cs_dtl_id"
      }
    },
    "bufferDPTable": {
      "type": "application:ojs/ojbufferingdataprovider",
      "constructorParams": [
        "{{ $variables.pamScheduleADP }}",
        null
      ]
    },
    "lvCurrentRow": {
      "type": "currentRowType",
      "defaultValue": {
        "project_id": 0
      }
    },
    "lvNextValue": {
      "type": "number",
      "defaultValue": 9999999999
    },
    "p_start_date": {
      "type": "string"
    },
    "p_end_date": {
      "type": "string"
    },
    "selectedScheduleId": {
      "type": "number"
    },
    "showDeleteDialog": {
      "type": "boolean",
      "defaultValue": false
    },
    "deleteScheduleId": {
      "type": "number"
    },
    "totalCount": {
      "type": "number",
      "defaultValue": 0
    },
    "totalRecords": {
      "type": "number",
      "defaultValue": 0
    },
    "editMode": {
      "type": "string",
      "defaultValue": "create"
    },
    "pNavCode": {
      "type": "string",
      "defaultValue": "CREATE"
    },
    "pNavId": {
      "type": "string"
    }

  },
  "metadata": {},
