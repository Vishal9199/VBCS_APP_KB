      "type": "string",
      "defaultValue": "location-plan-tab"
    },
    "editMode": {
      "type": "string",
      "defaultValue": "add"
    },
    "pNavCode": {
      "type": "string",
      "defaultValue": "CREATE",
      "required": true,
      "input": "fromUrl"
    },
    "pNavId": {
      "type": "string",
      "defaultValue": "0",
      "required": true,
      "input": "fromUrl"
    },
