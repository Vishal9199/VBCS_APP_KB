{
  "metadata": {},
  "title": "Project Charter Management",
  "description": "Add/Edit Project Charter with Details, Risks, Costs, and Attachments for comprehensive project planning and tracking.",
  "variables": {
    "about": {
      "type": "about"
    },
    "getPmispamProjectcharterLovParentprojectcharterListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "keyAttributes": "parent_project_charter_id",
        "itemsPath": "items",
        "responseType": "getPmispamProjectcharterLovParentprojectcharterResponse",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "parent_ref_num"
          ]
        },
        "fetchChain": "getPmispamProjectcharterLovParentprojectcharterFetch"
      }
    },
    "getRefNumberLovListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "keyAttributes": "lov_value",
        "itemsPath": "items",
        "responseType": "getRefNumberLovResponse",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "lov_label"
          ]
        },
        "fetchChain": "getRefNumberLovFetch"
      }
    },
    "isCostOrRisk": {
      "type": "string"
    },
    "isEstCreate": {
      "type": "string",
      "defaultValue": "Y"
    },
    "isRiskCreate": {
      "type": "string",
      "defaultValue": "Y"
    },
    "passKey": {
      "type": "string"
    },
    "passPayload": {
      "type": "string"
    },
    "projectCharterSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "responseType": "getPmispamFiveyearplandtlLovProjectname",
        "itemsPath": "items",
        "keyAttributes": "project_id",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "project_name"
          ]
        },
        "fetchChain": "getPmispamFiveyearplandtlLovProjectnameFetch"
      }
    },
    "projectCharterVar": {
      "type": "ProjectCharter",
      "defaultValue": {
        "last_updated_date": "[[ $application.functions.getSysdate() ]]",
        "created_date": "[[ $application.functions.getSysdate() ]]",
        "object_version_num": 0,
        "created_by": "[[ $application.user.email ]]",
        "last_updated_by": "[[ $application.user.email ]]",
        "last_updated_login": "[[ $application.user.email ]]"
      }
    },
    "majorRiskVar": {
      "type": "MajorRisk",
      "defaultValue": {
        "created_by": "[[ $application.user.email ]]",
        "last_updated_by": "[[ $application.user.email ]]",
        "last_updated_login": "[[ $application.user.email ]]",
        "created_date": "[[ $application.functions.getSysdate() ]]",
        "last_updated_date": "[[ $application.functions.getSysdate() ]]"
      }
    },
    "estimateCostVar": {
      "type": "EstimateCost",
      "defaultValue": {
        "created_by": "[[ $application.user.email ]]",
        "last_updated_by": "[[ $application.user.email ]]",
        "last_updated_login": "[[ $application.user.email ]]",
        "last_updated_date": "[[ $application.functions.getSysdate() ]]",
        "created_date": "[[ $application.functions.getSysdate() ]]"
      }
    },
