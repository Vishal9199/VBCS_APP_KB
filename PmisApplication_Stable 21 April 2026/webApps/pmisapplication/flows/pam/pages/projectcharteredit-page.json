        "transformsContext": {
          "vb-textFilterAttributes": [
            "location_name"
          ]
        }
      }
    },
    "getPmisLovProjectCharterStatusListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "endpoint": "PAM/getPmisLovProjectCharterStatusList",
        "keyAttributes": "lookup_value_id",
        "itemsPath": "items",
        "responseType": "getPmisLovProjectCharterStatusListResponse",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "status_name"
          ]
        }
      }
    },
    "projectCharterId": {
      "type": "number"
    },
    "aToolGeneric": {
      "type": "object[]"
    },
    "taskId": {
      "type": "string",
      "input": "fromUrl"
    },
    "dependencyVar": {
      "type": "Dependency",
      "defaultValue": {
        "created_by": "[[ $application.user.email ]]",
        "last_updated_by": "[[ $application.user.email ]]",
        "last_updated_login": "[[ $application.user.email ]]"
      }
    },
    "ADPdependency": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "Dependency",
        "keyAttributes": "dependency_id"
      }
    },
    "isDependencyCreate": {
      "type": "string",
      "defaultValue": "Y"
