      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "MajorRisk",
        "keyAttributes": "major_risk_id"
      }
    },
    "ADPestimateCost": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "EstimateCost",
