    },
    "getApprovalhistory": {
      "action_comments": "string",
      "action_date": "string",
      "action_history_id": "number",
      "action_id": "number",
      "action_sequence_num": "number",
      "action_type": "string",
      "action_type_code": "string",
      "action_type_id": "number",
      "appr_category_code": "string",
      "appr_category_id": "number",
      "appr_category_name": "string",
      "appr_hierarchy_id": "number",
      "appr_level": "number",
      "appr_request_code": "string",
      "appr_request_name": "string",
      "appr_role_id": "number",
      "appr_type_code": "string",
      "appr_type_id": "number",
      "appr_type_name": "string",
      "approval_pcs_instance_num": "string",
      "approval_role_code": "string",
      "approval_role_name": "string",
