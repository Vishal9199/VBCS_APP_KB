      }
    },
    "css": [
      "/resources/css/pmis-search.css"
    ]
  },
  "constants": {
    "TableColumnList": {
      "type": "object[]",
      "defaultValue": [
        {
          "headerText": "S.No",
          "field": "row_num",
          "resizable": "enabled"
        },
        {
          "headerText": "Approver",
          "field": "approver_email_id",
          "resizable": "enabled"
        },
        {
          "headerText": "Role",
          "field": "approval_role_name",
          "resizable": "enabled"
        },
        {
          "headerText": "Action",
          "field": "action_type",
          "resizable": "enabled"
        },
        {
          "headerText": "Comments",
          "field": "action_comments",
          "resizable": "enabled"
        },
        {
          "headerText": "Action Date",
          "field": "action_date",
          "resizable": "enabled",
