      "row_num": "number",
      "status_code": "string",
      "transaction_id": "number",
      "transaction_num": "string",
      "version_number": "number"
    }
  },
  "eventListeners": {
    "smartSearchPageTemplateSpPrimaryAction": {
      "chains": [
        {
          "chain": "onRefresh_AC",
          "parameters": {
            "event": "{{$event}}"
          }
        }
      ]
    },
    "smartSearchPageTemplateSpSecondaryAction": {
      "chains": [
        {
          "chain": "onClose_AC",
          "parameters": {
            "event": "{{$event}}",
            "secondaryItem": "{{$event.detail.secondaryItem}}",
            "actionId": "{{$event.detail.secondaryItem}}"
          }
        }
      ]
    },

    "vbEnter": {
      "chains": [
        {
          "parameters": {},
          "chain": "onLoad"
        }
      ]
    }

  },
  "imports": {
    "components": {
      "oj-button": {
        "path": "ojs/ojbutton"
      },
      "oj-dialog": {
        "path": "ojs/ojdialog"
      },
      "oj-file-picker": {
        "path": "ojs/ojfilepicker"
      },
      "oj-form-layout": {
