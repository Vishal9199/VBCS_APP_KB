{
  "title": "",
  "description": "",
  "variables": {

    "attachmentTableData": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "getApprovalhistory",
        "keyAttributes": "action_history_id"
      }
    },
    "pScreenName": {
      "type": "string",
      "defaultValue": "Approval History",
