  "eventListeners": {
    "hyperlinkClick": {
      "chains": [
        {
          "chain": "navigateToGeneral_AC",
          "parameters": {
            "event": "{{$event}}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "resetBtnAction": {
      "chains": [
        {
          "chain": "resetAction"
        }
      ]
    },
    "refreshBtnAction": {
