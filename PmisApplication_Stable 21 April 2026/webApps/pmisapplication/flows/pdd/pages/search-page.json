{
  "title": "Project Assignment Smart Search",
  "description": "Smart Search page for Project Assignment with encrypted payload, 8 LOV filters, and comprehensive table display",
  "variables": {
    "filterCriterion": {
      "type": "any",
      "onValueChanged": {
        "chains": [
          {
            "parameters": {
              "event": "{{ $event }}"
            },
            "chain": "filterCriterionListener"
          }
        ]
      }
    },
    "searchContext": {
      "type": "object",
      "defaultValue": {
        "$search": {
          "filters": {
            "TenderNameFilter": {
              "label": "Tender Name",
              "options": {
                "optionsData": "[[ $page.variables.getTenderNameLovSDP ]]",
                "optionsKeys": {
                  "label": "name",
                  "value": "id"
                }
              }
            },
            "TenderNumberFilter": {
              "label": "Tender Number",
              "options": {
                "optionsData": "[[ $page.variables.getTenderNumberLovSDP ]]",
                "optionsKeys": {
                  "label": "code",
                  "value": "id"
                }
              }
            },
            "ProjectNameFilter": {
              "label": "Project Name",
              "options": {
                "optionsData": "[[ $page.variables.getProjectNameLovSDP ]]",
                "optionsKeys": {
                  "label": "name",
                  "value": "id"
                }
              }
            },
            "ProjectNumberFilter": {
              "label": "Project Number",
              "options": {
                "optionsData": "[[ $page.variables.getProjectNumberLovSDP ]]",
                "optionsKeys": {
                  "label": "code",
                  "value": "id"
                }
              }
            },
            "GeneralManagerFilter": {
              "label": "General Manager",
              "options": {
                "optionsData": "[[ $page.variables.getGeneralManagerLovSDP ]]",
                "optionsKeys": {
                  "label": "person_full_name",
                  "value": "user_id"
                }
              }
            },
            "ProjectManagerFilter": {
              "label": "Project Manager",
              "options": {
                "optionsData": "[[ $page.variables.getProjectManagerLovSDP ]]",
                "optionsKeys": {
                  "label": "person_full_name",
                  "value": "user_id"
                }
              }
            },
            "RegionFilter": {
              "label": "Region",
              "options": {
                "optionsData": "[[ $page.variables.getRegionLovSDP ]]",
                "optionsKeys": {
                  "label": "region_name",
                  "value": "region_name"
                }
              }
            },
            "StatusFilter": {
              "label": "Status",
              "options": {
                "optionsData": "[[ $page.variables.getStatusLovSDP ]]",
                "optionsKeys": {
                  "label": "status_name",
                  "value": "status_code"
                }
              }
            }
          }
        }
      }
    },
    "searchConfiguration": {
      "type": "oj-sp/smart-search/strategies/JsonSearchConfigProviderFactory",
      "defaultValue": {
        "url": "[[ $application.path + 'resources/data/pddsearchconfig.json' ]]"
      }
    },
    "getTenderNameLovSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "responseType": "getTenderNameSearchLovCommon",
        "itemsPath": "items",
        "headers": {
          "x-session-code": "TENDER"
        },
        "fetchChain": "getPmispddSearchLovCommonFetch3",
        "keyAttributes": "id"

      }
    },
    "getTenderNumberLovSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "responseType": "getTenderNumberSearchLovCommon",
        "itemsPath": "items",
        "headers": {
          "x-session-code": "TENDER"
        },
        "fetchChain": "getPmispddSearchLovCommonFetch4",
        "keyAttributes": "id"

      }
    },
    "getProjectNameLovSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "responseType": "getPmispddSearchLovCommon",
        "itemsPath": "items",
        "headers": {
          "x-session-code": "PROJECT"
        },
        "fetchChain": "getPmispddSearchLovCommonFetch",
        "keyAttributes": "id"

      }
    },
    "getProjectNumberLovSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "responseType": "getProjectNumberSearchLovCommon",
        "itemsPath": "items",
        "fetchChain": "getPmispddSearchLovCommonFetch2",
        "keyAttributes": "id"

      }
    },
    "getGeneralManagerLovSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "responseType": "getPmispamLovUsers",
        "itemsPath": "items",
        "keyAttributes": "user_id",
        "fetchChain": "getPmispamLovUsersFetch"
      }
    },
    "getProjectManagerLovSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "itemsPath": "items",
        "responseType": "getPmispamLovUsers",
        "keyAttributes": "user_id",
        "fetchChain": "getProjectManagerLovFetch"
      }
    },
    "getRegionLovSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "responseType": "getPmispddSearchLovRegion",
        "itemsPath": "items",
        "keyAttributes": "region_name",
        "fetchChain": "getPmispddSearchLovRegionFetch"
      }
    },
    "getStatusLovSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "endpoint": "ProjectAssignmentService/getStatusLov",
        "keyAttributes": "status_code",
        "itemsPath": "items",
        "responseType": "getStatusLovResponse",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "status_name"
          ]
        }
      }
    },
    "searchObj": {
      "type": {
        "in_limit": "string",
        "in_offset": "string",
        "p_keyword": "string",
        "p_tender_id": "string",
        "p_tender_number": "string",
        "p_tender_name": "string",
        "p_project_id": "string",
        "p_project_number": "string",
        "p_project_name": "string",
        "p_general_manager_id": "string",
        "p_general_manager_name": "string",
        "p_proj_mgr_user_id": "string",
        "p_proj_mgr_name": "string",
        "p_region_code": "string",
        "p_status_code": "string"
      },
      "defaultValue": {
        "in_limit": "10",
        "in_offset": "0",
        "p_keyword": "",
        "p_tender_id": "",
        "p_tender_number": "",
        "p_tender_name": "",
        "p_project_id": "",
        "p_project_number": "",
        "p_project_name": "",
        "p_general_manager_id": "",
        "p_general_manager_name": "",
        "p_proj_mgr_user_id": "",
        "p_proj_mgr_name": "",
        "p_region_code": "",
        "p_status_code": ""
      }
    },
    "projectAssignmentADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "ProjectAssignmentType",
        "keyAttributes": "project_assignment_id"
      }
    },
    "paginationText": {
      "type": "string",
      "defaultValue": "Showing 0 to 0 of 0 records"
    },
    "currentPage": {
      "type": "number",
      "defaultValue": 1
    },
    "showNavigationMenu": {
      "type": "boolean",
      "defaultValue": false
    },
    "totalRecords": {
      "type": "number",
      "defaultValue": 0
    },
    "hasNextPage": {
      "type": "string",
      "defaultValue": "N"
    },
    "isSearching": {
      "type": "boolean",
      "defaultValue": false,
      "description": "Loading indicator for search operations"
    },
    "isPrevDisabled": {
      "type": "boolean",
      "defaultValue": true,
      "description": "Disable state for Previous button"
    },
    "isNextDisabled": {
      "type": "boolean",
      "defaultValue": true,
      "description": "Disable state for Next button"
    },
    "selectedRowData": {
      "type": "ProjectAssignmentType",
      "description": "Stores currently selected row for edit/delete operations"
    },
    "encryptionKey": {
      "type": "string",
      "defaultValue": "YOUR_ENCRYPTION_KEY_HERE",
      "description": "Encryption key for payload security"
    },
    "encryptedPayload": {
      "type": "string",
      "defaultValue": "",
      "description": "Temporary storage for encrypted payload"
    },
    "searchResponse": {
      "type": {
        "out_status": "string",
        "out_description": "string",
        "out_has_next": "string",
        "out_total_count": "number",
        "out_count": "number",
        "p_output": "any"
      },
      "description": "Raw response from search endpoint"
    },
    "pagination": {
      "type": "object",
      "defaultValue": {
        "is_next": false,
        "is_prev": true
      }
    },
    "paginationDisplay": {
      "type": "string",
      "defaultValue": "0 - 0 of 0 items"
    }

  },
  "metadata": {},
