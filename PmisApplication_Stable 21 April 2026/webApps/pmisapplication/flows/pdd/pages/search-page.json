  "constants": {
    "tableColumns": {
      "type": "object[]",
      "defaultValue": "[[ [\n    {\n        \"headerText\": \"Project Number\",\n        \"field\": \"ora_project_number\",\n        \"frozenEdge\": \"start\",\n        \"resizable\": \"enabled\",\n        \"width\": 200,\n        \"template\": \"project_number_template\",\n        \"headerStyle\": \"white-space: nowrap; min-width: 200px;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"Project Name\",\n        \"field\": \"ora_project_name\",\n        \"frozenEdge\": \"start\",\n        \"resizable\": \"enabled\",\n        \"width\": 200,\n        \"template\": \"project_name_template\",\n        \"headerStyle\": \"white-space: nowrap; min-width: 200px;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"Tender Number\",\n        \"field\": \"tender_number\",\n        \"frozenEdge\": \"start\",\n        \"resizable\": \"enabled\",\n        \"width\": 160,\n        \"template\": \"tender_number_template\",\n        \"headerStyle\": \"white-space: nowrap; min-width: 160px;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"Tender Name\",\n        \"field\": \"tender_name\",\n        \"resizable\": \"enabled\",\n        \"width\": 160,\n        \"template\": \"tender_name_template\",\n        \"headerStyle\": \"white-space: nowrap; min-width: 160px;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"Tender Type\",\n        \"field\": \"tender_type\",\n        \"resizable\": \"enabled\",\n        \"width\": 180,\n        \"template\": \"tender_type_template\",\n        \"headerStyle\": \"white-space: nowrap; min-width: 180px;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"Region\",\n        \"field\": \"region_name\",\n        \"resizable\": \"enabled\",\n        \"width\": 180,\n        \"template\": \"region_template\",\n        \"headerStyle\": \"white-space: nowrap; min-width: 180px;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"General Manager\",\n        \"field\": \"senior_manager_name\",\n        \"resizable\": \"enabled\",\n        \"width\": 180,\n        \"template\": \"senior_manager_template\",\n        \"headerStyle\": \"white-space: nowrap; min-width: 180px;\",\n        \"style\": \"\"\n    },\n    {\n        \"headerText\": \"Project Manager\",\n        \"field\": \"project_manager_name\",\n        \"resizable\": \"enabled\",\n        \"width\": 180,\n        \"template\": \"project_manager_template\",\n        \"headerStyle\": \"white-space: nowrap; min-width: 180px;\",\n        \"style\": \"\"\n    }\n] ]]"    }
