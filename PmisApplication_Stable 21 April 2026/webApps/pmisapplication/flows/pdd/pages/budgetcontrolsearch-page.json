      },
      "oj-form-layout": {
        "path": "ojs/ojformlayout"
      },
      "oj-input-number": {
        "path": "ojs/ojinputnumber"
      },
      "oj-input-text": {
        "path": "ojs/ojinputtext"
      },
      "oj-list-view": {
        "path": "ojs/ojlistview"
      },
      "oj-select-single": {
        "path": "ojs/ojselectsingle"
      },
      "oj-sp-collection-container": {
        "path": "oj-sp/collection-container/loader"
      },
      "oj-sp-empty-state": {
        "path": "oj-sp/empty-state/loader"
      },
      "oj-sp-list-item-template": {
        "path": "oj-sp/list-item-template/loader"
      },
      "oj-sp-smart-search": {
        "path": "oj-sp/smart-search/loader"
      },
      "oj-sp-smart-search-page": {
        "path": "oj-sp/smart-search-page/loader"
      },
      "oj-table": {
        "path": "ojs/ojtable"
      }

    },
    "modules": {
      "ojConverterNumber": {
        "path": "ojs/ojconverter-number"
      },
      "ojValidationNumber": {
        "path": "ojs/ojvalidation-number"
      }
    }
  },
  "@dt": {
    "iconClass": "vbdt-dynamic-icon-17-icoSmartSearchPage48Svg"
  },
  "constants": {
    "columnsVar": {
      "type": "object[]",
      "defaultValue": [
        {
          "headerText": "Actions",
          "field": "",
          "frozenEdge": "start",
          "resizable": "disabled",
          "sortable": "disabled",
          "template": "actions",
          "headerStyle": "white-space: nowrap; min-width: 100px;",
          "style": ""
        },
        {
          "headerText": "Project Name",
          "field": "ora_project_name",
          "resizable": "enabled",
          "template": "edit_link",
          "headerStyle": "white-space: nowrap; min-width: 180px;",
          "style": ""
        },
        {
          "headerText": "Region Name",
          "field": "region",
          "resizable": "enabled",
          "template": "region_name",
          "headerStyle": "white-space: nowrap; min-width: 150px;",
          "style": ""
        },
        {
          "headerText": "Plan Type",
          "field": "plan_type",
          "headerStyle": "white-space: nowrap; min-width: 180px;",
          "style": ""
        },
        {
          "headerText": "Year",
          "field": "year",
          "frozenEdge": "start",
          "resizable": "enabled",
          "headerStyle": "white-space: nowrap; min-width: 180px;",
          "style": ""
        }
      ]
    }
  }
}
