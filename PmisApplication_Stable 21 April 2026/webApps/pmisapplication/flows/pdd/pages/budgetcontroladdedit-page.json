  "@dt": {
    "iconClass": "vbdt-dynamic-icon-1-icoAdvancedCreateAndEdit48Svg"
  },
  "layouts": {
    "containerLayout1": {
      "label": "Container Rule Set 1",
      "layoutType": "container",
      "layouts": {
        "case1": {
          "label": "Case 1",
          "layoutType": "container",
          "layout": {
            "sectionTemplateMap": {
              "template1": "template1",
              "template2": "template2"
            },
            "displayProperties": [
              "template1",
              "template2"
            ]
          }
        }
      },
      "rules": [
        "containerLayout1-rule1"
      ]
    },
    "containerLayout1-rule1": {
      "expression": "case1"
    }
  },
  "templates": {
    "template1": {
      "title": "Section 1",
      "description": "Sample Section 1",
      "extensible": "byReference",
      "@dt": {
        "type": "section",
        "layout": "containerLayout1"
      },
      "dependencies": [
        "oj-dynamic/form/loader",
        "oj-sp/section/loader"
      ],
      "labelHint": "Sample Section 1"
    },
    "template2": {
      "title": "Section 2",
      "description": "Sample Section 2",
      "extensible": "byReference",
      "@dt": {
        "layout": "containerLayout1",
        "type": "section"
      },
      "dependencies": [
        "oj-dynamic/form/loader",
        "oj-sp/section/loader"
      ],
      "labelHint": "Sample Section 2"
    }
  }
