  "eventListeners": {
    "aboutButtonCancelACAction": {
      "chains": [
        {
          "chain": "onCloseAbout_AC",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },

    "vbEnter": {
      "chains": [
        {
          "parameters": {},
          "chain": "vbEnterListener"
        }
      ]
    },
    "budgetcontrolidSpPrimaryAction": {
      "chains": [
        {
          "chain": "onClickCancel"
        }
      ]
    },
    "budgetcontrolidSpSecondaryAction": {
      "chains": [
        {
          "chain": "AdvancedCreateAndEditPageTemplateSpSecondaryActionChain",
          "parameters": {
            "event": "{{$event}}",
            "secondaryItem": "{{$event.detail.secondaryItem}}",
            "actionId": "{{ $event.detail.secondaryItem }}"
          }
        }
      ]
    },
    "btnEnterBudgetAction": {
      "chains": [
        {
          "chain": "onClickEnterBudget"
        }
      ]
    },
    "btnUpdateBudgetAction": {
      "chains": [
        {
          "chain": "onClickUpdateBudget"
        }
      ]
    },
    "btnSaveBudgetAction": {
      "chains": [
        {
          "chain": "onClickSaveBudget"
        }
      ]
    },
    "budgetBeforeRowEdit": {
      "chains": [
        {
          "chain": "BudgetBeforeRowEditChain",
          "parameters": {
            "rowKey": "{{ $event.detail.rowContext.status.rowKey }}",
            "rowIndex": "{{ $event.detail.rowContext.status.rowIndex }}",
            "rowData": "{{ $event.detail.rowContext.componentElement.getDataForVisibleRow($event.detail.rowContext.status.rowIndex).data }}"
          }
        }
      ]
    },
    "budgetBeforeRowEditEnd": {
      "chains": [
        {
          "chain": "BudgetBeforeRowEditEndChain",
          "parameters": {
            "cancelEdit": "{{ $event.detail.cancelEdit }}",
            "rowKey": "{{ $event.detail.rowContext.status.rowKey }}",
            "rowIndex": "{{ $event.detail.rowContext.status.rowIndex }}",
            "rowData": "{{ $event.detail.rowContext.componentElement.getDataForVisibleRow($event.detail.rowContext.status.rowIndex).data }}",
            "updatedRow": "[[ $variables.lvBudgetCurrentRow ]]"
          }
        }
      ]
    },
    "yearLovAction": {
      "chains": [
        {
          "chain": "onYearChange_AC",
          "parameters": {
            "selectedYear": "{{$event.detail.value}}"
          }
        }
      ]
    }

  },
