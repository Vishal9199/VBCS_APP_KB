        "created_by": "[[ $application.user.email ]]"
      }
    },
    "pTenderId": {
      "type": "string",
      "required": true,
      "input": "fromUrl"
    },
    "budgetLinesADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "BudgetLineType",
        "keyAttributes": "budget_control_line_id"
      }
    },
    "bufferDPBudgetLines": {
      "type": "application:ojs/ojbufferingdataprovider",
      "constructorParams": [
        "{{ $variables.budgetLinesADP }}",
        null
      ]
    },
    "lvBudgetCurrentRow": {
