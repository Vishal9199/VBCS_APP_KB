  "eventListeners": {
    "vbEnter": {
      "chains": [
        {
          "chain": "vbEnterListener"
        }
      ]
    },
    "saveBtn": {
      "chains": [
        {
          "chain": "onClickSaveAC"
        }
      ]
    },
    "refreshBtn": {
      "chains": [
        {
          "chain": "SynADPFutureProjectsAC"
        }
      ]
    },
    "resetBtn": {
      "chains": [
        {
          "chain": "resetSearchAC"
        }
      ]
    },
    "preBtn": {
      "chains": [
        {
          "chain": "prevPageAC"
        }
      ]
    },
    "nxtBtn": {
      "chains": [
        {
          "chain": "nextPageAC"
        }
      ]
    },
    "futureProjectsTblBeforeRowEdit": {
      "chains": [
        {
          "chain": "TableBeforeRowEditChain",
          "parameters": {
            "rowKey": "{{ $event.detail.rowContext.status.rowKey }}",
            "rowIndex": "{{ $event.detail.rowContext.status.rowIndex }}",
            "rowData": "{{ $event.detail.rowContext.componentElement.getDataForVisibleRow($event.detail.rowContext.status.rowIndex).data }}"
          }
        }
      ]
    },
    "futureProjectsTblBeforeRowEditEnd": {
      "chains": [
        {
          "chain": "TableBeforeRowEditEndChain",
          "parameters": {
            "cancelEdit": "{{ $event.detail.cancelEdit }}",
            "rowKey": "{{ $event.detail.rowContext.status.rowKey }}",
            "rowIndex": "{{ $event.detail.rowContext.status.rowIndex }}",
            "rowData": "{{ $event.detail.rowContext.componentElement.getDataForVisibleRow($event.detail.rowContext.status.rowIndex).data }}",
            "updatedRow": "[[ $variables.lvCurrentRow ]]"
          }
        }
      ]
    },
    "deleteConfirmBtn": {
      "chains": [
        {
          "chain": "deleteRowAC"
        }
      ]
    },
    "deleteCancelBtn": {
      "chains": [
        {
          "chain": "closeDeleteDialogAC"
        }
      ]
    },
    "deleteRowBtn": {
      "chains": [
        {
          "chain": "openDeleteDialogAC",
          "parameters": {
            "rowKey": "{{ $current.key }}",
            "rowData": "{{ $current.row }}"
          }
        }
      ]
    },
    "addProjectBtn": {
      "chains": [
        {
          "chain": "onAddProjectAC"
        }
      ]
    }
  },
