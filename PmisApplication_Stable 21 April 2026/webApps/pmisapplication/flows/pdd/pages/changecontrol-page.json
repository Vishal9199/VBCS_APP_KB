  "variables": {
    "aToolBar": {
      "type": "object[]",
      "defaultValue": [
        {
          "label": "Save",
          "id": "save",
          "icon": "oj-ux-ico-save"
        }
      ]
    },
    "count": {
      "type": "number"
    },
    "getPmispddChangecontrolLovCrListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "endpoint": "PDD/getPmispddChangecontrolLovCr",
        "keyAttributes": "change_request_id",
        "itemsPath": "items",
        "responseType": "getPmispddChangecontrolLovCrResponse",
        "headers": {
          "x-session-id": "{{ $variables.pTenderId }}"
        },
        "transformsContext": {
          "vb-textFilterAttributes": [
            "cr_number"
          ]
        }
      }
    },
    "getPmispddChangecontrolLovIfopenListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "endpoint": "PDD/getPmispddChangecontrolLovIfopen",
        "keyAttributes": "lookup_value_id",
        "itemsPath": "items",
        "responseType": "getPmispddChangecontrolLovIfopenResponse",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "lookup_value_name"
          ]
        }
      }
    },
    "getPmispddStakeholderLovStatusListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "endpoint": "PDD/getPmispddStakeholderLovStatus",
        "itemsPath": "items",
        "responseType": "getPmispddStakeholderLovStatusResponse",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "lookup_value_name"
          ]
        },
        "keyAttributes": "lookup_value_name"
      }
    },
    "original_contract_value": {
      "type": "number",
      "defaultValue": 5678
    },
    "revised_contract_amount": {
      "type": "number",
      "defaultValue": 5678
    },
    "rowToEdit": {
      "type": {
        "rowKey": "number"
      }
    },
    "passKey": {
      "type": "string"
    },
    "passPayload": {
      "type": "string"
    },
    "pTenderId": {
      "type": "string",
      "required": true,
      "input": "fromUrl"
    },
    "lvNextHeaderValue": {
      "type": "number",
      "defaultValue": 9999999
    },
    "getPmispddChangeControlLovCrListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "endpoint": "PDD/getPmispddChangeControlLovCr",
        "keyAttributes": "change_request_id",
        "itemsPath": "items",
        "responseType": "getPmispddChangeControlLovCrResponse",
