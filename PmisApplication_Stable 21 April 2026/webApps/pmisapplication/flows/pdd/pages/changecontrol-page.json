      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "ChangeControlDetailType",
        "keyAttributes": "control_register_id"
      }
    },
    "bufferDPChangeControlTable": {
      "type": "application:ojs/ojbufferingdataprovider",
      "constructorParams": [
        "{{ $variables.ADPChangeControlTable }}",
        null
      ]
    },
    "lvCurrentChangeControlRow": {
      "type": "CurrentChangeControlRowType"
    },
    "tablecolumns": {
      "type": "object[]",
      "defaultValue": [
        {
          "headerText": "Actions",
          "field": "",
          "template": "actionsTemplate",
          "width": 90,
          "headerStyle": "white-space: normal;",
          "style": ""
        },
        {
          "headerText": "CR No",
          "field": "cr_number",
          "template": "crNumberTemplate",
          "resizable": "enabled",
          "width": 130,
          "headerStyle": "white-space: normal;",
          "style": ""
        },
        {
          "headerText": "VO No",
          "field": "vo_number",
          "template": "voNumberTemplate",
          "resizable": "enabled",
          "width": 120,
          "headerStyle": "white-space: normal;",
          "style": ""
        },
        {
          "headerText": "Project Manager",
          "field": "project_manager",
          "template": "projectManagerTemplate",
          "resizable": "enabled",
          "width": 160,
          "headerStyle": "white-space: normal;",
          "style": ""
        },
        {
          "headerText": "Initiator",
          "field": "initiator",
          "template": "initiatorTemplate",
          "resizable": "enabled",
          "width": 120,
          "headerStyle": "white-space: normal;",
          "style": ""
        },
        {
          "headerText": "EOT (Days)",
          "field": "time_impact",
          "template": "timeImpactTemplate",
          "resizable": "enabled",
          "width": 100,
          "headerStyle": "white-space: normal;",
          "style": ""
        },
        {
          "headerText": "Addition (A) OMR",
          "field": "addition_a",
          "template": "additionATemplate",
          "resizable": "enabled",
          "width": 140,
          "headerStyle": "white-space: normal;",
          "style": ""
        },
        {
          "headerText": "Omission (B) OMR",
          "field": "omission_b",
          "template": "omissionBTemplate",
          "resizable": "enabled",
          "width": 140,
          "headerStyle": "white-space: normal;",
          "style": ""
        },
        {
          "headerText": "Total Change (C=A+B) OMR",
          "field": "total_change",
          "template": "totalChangeTemplate",
          "resizable": "enabled",
          "width": 170,
          "headerStyle": "white-space: normal;",
          "style": ""
        },
        {
          "headerText": "Net Change (D=A-B) OMR",
          "field": "net_change",
          "template": "netChangeTemplate",
          "resizable": "enabled",
          "width": 160,
          "headerStyle": "white-space: normal;",
          "style": ""
        },
        {
          "headerText": "Net Percent Change (A-B/Z)",
          "field": "net_percentage_of_change",
          "template": "netPercentTemplate",
          "resizable": "enabled",
          "width": 170,
          "headerStyle": "white-space: normal;",
          "style": ""
        },
        {
          "headerText": "Total Vol. of Change (E=C/Z) %",
          "field": "total_vol_of_change",
          "template": "totalVolTemplate",
          "resizable": "enabled",
          "width": 180,
          "headerStyle": "white-space: normal;",
          "style": ""
        },
        {
          "headerText": "Status",
          "field": "status",
          "template": "statusTemplate",
          "resizable": "enabled",
          "width": 110,
          "headerStyle": "white-space: normal;",
          "style": ""
        },
        {
          "headerText": "If Open",
          "field": "open_reason",
          "template": "ifOpenTemplate",
          "resizable": "enabled",
          "width": 140,
          "headerStyle": "white-space: normal;",
          "style": ""
        },
        {
          "headerText": "Remarks",
          "field": "remarks",
          "template": "remarksTemplate",
          "resizable": "enabled",
          "width": "",
          "headerStyle": "white-space: normal;",
          "style": ""
        }
      ]
    }
  },
  "metadata": {},
