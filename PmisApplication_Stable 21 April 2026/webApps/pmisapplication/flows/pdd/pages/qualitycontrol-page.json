            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "inputTextValue": {
      "chains": [
        {
          "chain": "InputTextValueChangeChain",
          "parameters": {
            "event": "{{$event}}",
            "previousValue": "{{$event.detail.previousValue}}",
            "value": "{{ $event.detail.value }}",
            "updatedFrom": "{{$event.detail.updatedFrom}}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "inputTextValue2": {
      "chains": [
        {
          "chain": "onCiForMonthChange",
          "parameters": {
            "event": "{{$event}}",
            "previousValue": "{{$event.detail.previousValue}}",
            "value": "{{ $event.detail.value }}",
            "updatedFrom": "{{$event.detail.updatedFrom}}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "inputTextValue3": {
      "chains": [
        {
          "chain": "onCiPendingChange",
          "parameters": {
            "event": "{{$event}}",
            "previousValue": "{{$event.detail.previousValue}}",
            "value": "{{ $event.detail.value }}",
            "updatedFrom": "{{$event.detail.updatedFrom}}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "inputTextValue4": {
      "chains": [
        {
          "chain": "onQcValueChange_AC",
          "parameters": {
            "event": "{{$event}}",
            "previousValue": "{{$event.detail.previousValue}}",
            "value": "{{ $event.detail.value }}",
            "updatedFrom": "{{$event.detail.updatedFrom}}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "qualityControlPageSpPrimaryAction": {
      "chains": [
        {
          "chain": "onClosePrimary_AC",
          "parameters": {
            "event": "{{$event}}"
          }
        }
      ]
    },
    "qualityControlPageSpSecondaryAction": {
      "chains": [
        {
          "chain": "secondary_AC",
          "parameters": {
            "event": "{{$event}}",
            "secondaryItem": "{{$event.detail.secondaryItem}}",
            "actionId": "{{$event.detail.secondaryItem}}"
          }
        }
      ]
    },
    "qualityControlTabBarSelection": {
      "chains": [
        {
          "chain": "selectedTabListener",
          "parameters": {
            "event": "{{ $event }}",
            "value": "{{ $event.detail.value }}",
            "selection": "{{ $event.detail.value }}",
            "previousValue": "{{$event.detail.previousValue}}",
            "updatedFrom": "{{$event.detail.updatedFrom}}"
          }
        }
      ]
    },
    "vbAfterNavigate": {
      "chains": [
        {
          "parameters": { "event": "{{ $event }}" },
          "chain": "vbAfterNavigateListener"
        }
      ]
    },
    "vbEnter": {
      "chains": [
        { "chain": "vbEnterListener",
           "parameters": {}
     }
      ]
    },
    "addQualityAssuranceBtnAction": {
      "chains": [ { "chain": "addQualityAssuranceRowsChain" } ]
    },
    "addContinualImproveBtnAction": {
      "chains": [ { "chain": "addContinualImproveRowsChain" } ]
    },
    "addQualityControlBtnAction": {
      "chains": [ { "chain": "addQualityControlRowsChain" } ]
    },
    "addDisciplineBtnAction": {
      "chains": [ { "chain": "addDisciplineRowsChain" } ]
    },
    "saveQualityAssuranceBtnAction": {
      "chains": [ { "chain": "saveQualityAssuranceChain" } ]
    },
    "saveContinualImproveBtnAction": {
      "chains": [ { "chain": "saveContinualImproveChain" } ]
    },
    "saveQualityControlBtnAction": {
      "chains": [ { "chain": "saveQualityControlChain" } ]
    },
    "saveDisciplineBtnAction": {
      "chains": [ { "chain": "saveDisciplineChain" } ]
    },
    "qaTableBeforeRowEdit": {
      "chains": [
        {
          "parameters": {
            "rowKey": "{{$event.detail.rowContext.status.rowKey}}",
            "rowIndex": "{{$event.detail.rowContext.status.rowIndex}}",
            "rowData": "{{$event.detail.rowContext.componentElement.getDataForVisibleRow($event.detail.rowContext.status.rowIndex).data}}"
          },
          "chain": "qaBeforeRowEditChain"
        }
      ]
    },
    "qaTableBeforeRowEditEnd": {
      "chains": [
        {
          "parameters": {
            "cancelEdit": "{{ $event.detail.cancelEdit }}",
            "rowKey": "{{$event.detail.rowContext.status.rowKey}}",
            "rowIndex": "{{$event.detail.rowContext.status.rowIndex}}",
            "rowData": "{{$event.detail.rowContext.componentElement.getDataForVisibleRow($event.detail.rowContext.status.rowIndex).data}}",
            "updatedRow": "[[ $variables.qaCurrentRow ]]"
          },
          "chain": "qaBeforeRowEditEndChain"
        }
      ]
    },
    "ciTableBeforeRowEdit": {
      "chains": [
        {
          "parameters": {
            "rowKey": "{{$event.detail.rowContext.status.rowKey}}",
            "rowIndex": "{{$event.detail.rowContext.status.rowIndex}}",
            "rowData": "{{$event.detail.rowContext.componentElement.getDataForVisibleRow($event.detail.rowContext.status.rowIndex).data}}"
          },
          "chain": "ciBeforeRowEditChain"
        }
      ]
    },
    "ciTableBeforeRowEditEnd": {
      "chains": [
        {
          "parameters": {
           "cancelEdit": "{{$event.detail.cancelEdit}}",
            "rowKey": "{{$event.detail.rowContext.status.rowKey}}",
            "rowIndex": "{{$event.detail.rowContext.status.rowIndex}}",
            "rowData": "{{$event.detail.rowContext.componentElement.getDataForVisibleRow($event.detail.rowContext.status.rowIndex).data}}",
            "updatedRow": "[[ $variables.ciCurrentRow ]]"
          },
          "chain": "ciBeforeRowEditEndChain"
        }
      ]
    },
    "qcTableBeforeRowEdit": {
      "chains": [
        {
          "parameters": {
            "rowKey": "{{$event.detail.rowContext.status.rowKey}}",
            "rowIndex": "{{$event.detail.rowContext.status.rowIndex}}",
            "rowData": "{{$event.detail.rowContext.componentElement.getDataForVisibleRow($event.detail.rowContext.status.rowIndex).data}}"
          },
          "chain": "qcBeforeRowEditChain"
        }
      ]
    },
    "qcTableBeforeRowEditEnd": {
      "chains": [
        {
          "parameters": {
            "cancelEdit": "{{$event.detail.cancelEdit}}",
            "rowKey": "{{$event.detail.rowContext.status.rowKey}}",
            "rowIndex": "{{$event.detail.rowContext.status.rowIndex}}",
            "rowData": "{{$event.detail.rowContext.componentElement.getDataForVisibleRow($event.detail.rowContext.status.rowIndex).data}}",
            "updatedRow": "[[ $variables.qcCurrentRow ]]"
          },
          "chain": "qcBeforeRowEditEndChain"
        }
      ]
    },
    "discTableBeforeRowEdit": {
      "chains": [
        {
          "parameters": {
            "rowKey": "{{$event.detail.rowContext.status.rowKey}}",
            "rowIndex": "{{$event.detail.rowContext.status.rowIndex}}",
            "rowData": "{{$event.detail.rowContext.componentElement.getDataForVisibleRow($event.detail.rowContext.status.rowIndex).data}}"
          },
          "chain": "discBeforeRowEditChain"
        }
      ]
    },
    "discTableBeforeRowEditEnd": {
      "chains": [
        {
          "parameters": {
            "cancelEdit": "{{$event.detail.cancelEdit}}",
            "rowKey": "{{$event.detail.rowContext.status.rowKey}}",
            "rowIndex": "{{$event.detail.rowContext.status.rowIndex}}",
            "rowData": "{{$event.detail.rowContext.componentElement.getDataForVisibleRow($event.detail.rowContext.status.rowIndex).data}}",
            "updatedRow": "[[ $variables.discCurrentRow ]]"
          },
          "chain": "discBeforeRowEditEndChain"
        }
      ]
    },
    "onDiscValueChange": {
      "chains": [
        {
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          },
          "chain": "onDiscValueChange_AC"
        }
      ]
    }

  }
}