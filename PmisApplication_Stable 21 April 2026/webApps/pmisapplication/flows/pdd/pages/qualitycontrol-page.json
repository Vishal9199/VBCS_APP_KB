{
  "variables": {
    "pTenderId": {
      "type": "string",
      "required": true,
      "input": "fromUrl"
    },
    "pType": {
      "type": "string"
    },
    "tempNcrValue": {
      "type": "number"
    },
    "tenderId": {
      "type": "string"
    },
    "period": {
      "type": "string",
      "description": "Temporary Value",
      "defaultValue": "FEB-26"
    },
    "projectNumber": {
      "type": "string"
    },
    "projectName": {
      "type": "string"
    },
    "tenderNumber": {
      "type": "string"
    },
    "userName": {
      "type": "string"
    },
    "selectedTab": {
      "type": "string",
      "defaultValue": "qualityAssurance"
    },
    "progressDialogOpen": {
      "type": "boolean",
      "defaultValue": false
    },
    "qualityAssuranceADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "qualityAssuranceType",
        "keyAttributes": "quality_assurance_id"
      }
    },
    "qualityAssuranceData": {
      "type": "qualityAssuranceType[]",
      "defaultValue": []
    },
    "qaBufferDP": {
      "type": "application:ojs/ojbufferingdataprovider",
      "constructorParams": [
        "{{ $variables.qualityAssuranceADP }}",
        null
      ]
    },
    "qaCurrentRow": {
      "type": "qualityAssuranceType"
    },
    "continualImproveADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "keyAttributes": "continual_improve_id",
        "itemType": "continualImproveType"
      }
    },
    "continualImproveData": {
      "type": "continualImproveType[]",
      "defaultValue": []
    },
    "ciBufferDP": {
      "type": "application:ojs/ojbufferingdataprovider",
      "constructorParams": [
        "{{ $variables.continualImproveADP }}",
        null
      ]
    },
    "ciCurrentRow": {
      "type": "continualImproveType"
    },
    "qualityControlADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "keyAttributes": "quality_control_id",
        "itemType": "qualityControlType"
      }
    },
    "qualityControlData": {
      "type": "qualityControlType[]",
      "defaultValue": []
    },
    "qcBufferDP": {
      "type": "application:ojs/ojbufferingdataprovider",
      "constructorParams": [
        "{{ $variables.qualityControlADP }}",
        null
      ]
    },
    "qcCurrentRow": {
      "type": "qualityControlType"
    },
    "disciplineADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "keyAttributes": "discipline_id",
        "itemType": "disciplineType"
      }
    },
    "disciplineData": {
      "type": "disciplineType[]",
      "defaultValue": []
    },
    "discBufferDP": {
      "type": "application:ojs/ojbufferingdataprovider",
      "constructorParams": [
        "{{ $variables.disciplineADP }}",
        null
      ]
    },
    "discCurrentRow": {
      "type": "disciplineType"
    },
    "qaRowToEdit": {
      "type": {
        "rowKey": "number"
      }
    },
    "ciRowToEdit": {
      "type": {
        "rowKey": "number"
      }
    },
    "qcRowToEdit": {
      "type": {
        "rowKey": "number"
      }
    },
    "discRowToEdit": {
      "type": {
        "rowKey": "number"
      }
    },
    "about": {
        "type": "AboutType"
    }

  },
  "types": {
    "qualityAssuranceType": {
      "quality_assurance_id": "number",
      "object_version_num": "number",
