  "imports": {
    "components": {
      "oj-panel": { "path": "ojs/ojpanel" },
      "oj-form-layout": { "path": "ojs/ojformlayout" },
      "oj-input-text": { "path": "ojs/ojinputtext" },
      "oj-input-number": { "path": "ojs/ojinputnumber" },
      "oj-label": { "path": "ojs/ojlabel" },
      "oj-sp-advanced-create-edit": { "path": "oj-sp/advanced-create-edit/loader" },
      "oj-tab-bar": { "path": "ojs/ojnavigationlist" },
      "oj-switcher": { "path": "ojs/ojswitcher" },
      "oj-table": { "path": "ojs/ojtable" },
      "oj-text-area": { "path": "ojs/ojtextarea" },
      "oj-button": { "path": "ojs/ojbutton" },
      "oj-toolbar": { "path": "ojs/ojtoolbar" },
      "oj-dialog": { "path": "ojs/ojdialog" },
      "oj-progress-bar": { "path": "ojs/ojprogress-bar" },
      "oj-collapsible": { "path": "ojs/ojcollapsible" },
      "oj-bind-text": { "path": "ojs/ojbindtext" },
      "oj-bind-if": { "path": "ojs/ojbindif" }
    },
    "css": [
      "/resources/css/pmis-addedit.css"
    ]
  },
  "constants": {
    "qualityAssuranceColumns": {
      "type": "object[]",
      "defaultValue": [
        { "headerText": "Actions", "field": "", "template": "qaActionTemplate", "frozenEdge": "start", "sortable": "disabled", "resizable": "disabled", "width": 80, "headerStyle": "white-space: normal;" },
        { "headerText": "Activity", "field": "activity_name", "template": "activityTemplate", "frozenEdge": "start", "sortable": "disabled", "resizable": "enabled", "width": 250, "headerStyle": "white-space: normal;" },
        { "headerText": "Done For Month", "field": "activity_done_for_month", "template": "activityDoneForMonthTemplate", "sortable": "disabled", "resizable": "enabled", "width": 150, "headerStyle": "white-space: normal;" },
        { "headerText": "Total Cumulative", "field": "activity_total_cumm", "template": "activityTotalCummTemplate", "sortable": "disabled", "resizable": "enabled", "width": 150, "headerStyle": "white-space: normal;" },
        { "headerText": "Remark", "field": "activity_remark", "template": "activityRemarkTemplate", "sortable": "disabled", "resizable": "enabled", "width": "", "headerStyle": "white-space: normal;" }
      ]
    },
    "continualImproveColumns": {
      "type": "object[]",
      "defaultValue": [
        { "headerText": "Actions", "field": "", "template": "ciActionTemplate", "frozenEdge": "start", "sortable": "disabled", "resizable": "disabled", "width": 80, "headerStyle": "white-space: normal;" },
        { "headerText": "Mechanism Type", "field": "mechanism_type", "template": "mechanismTypeTemplate", "frozenEdge": "start", "sortable": "disabled", "resizable": "enabled", "width": 250, "headerStyle": "white-space: normal;" },
        { "headerText": "For the Month", "field": "mechanism_for_month", "template": "mechanismForMonthTemplate", "sortable": "disabled", "resizable": "enabled", "width": 130, "headerStyle": "white-space: normal;" },
        { "headerText": "Total (Cumulative)", "field": "mechanism_total_cumm", "template": "mechanismTotalCummTemplate", "sortable": "disabled", "resizable": "enabled", "width": 150, "headerStyle": "white-space: normal;" },
        { "headerText": "Pending/Open", "field": "mechanism_pending_open", "template": "mechanismPendingOpenTemplate", "sortable": "disabled", "resizable": "enabled", "width": 130, "headerStyle": "white-space: normal;" },
        { "headerText": "Closed NCR", "field": "closed_ncr", "template": "closedNcrTemplate", "sortable": "disabled", "resizable": "enabled", "width": 120, "headerStyle": "white-space: normal;" },
        { "headerText": "Remarks", "field": "mechanism_remarks", "template": "mechanismRemarksTemplate", "sortable": "disabled", "resizable": "enabled", "width": "", "headerStyle": "white-space: normal;" }
      ]
    },
    "qualityControlColumns": {
      "type": "object[]",
      "defaultValue": [
        { "headerText": "Actions", "field": "", "template": "qcActionTemplate", "frozenEdge": "start", "sortable": "disabled", "resizable": "disabled", "width": 80, "headerStyle": "white-space: normal;" },
        { "headerText": "Type of Tests", "field": "quality_control", "template": "qualityControlTemplate", "frozenEdge": "start", "sortable": "disabled", "resizable": "enabled", "width": 180, "headerStyle": "white-space: normal;" },
        { "headerText": "Total for the Month", "field": "qc_total_month", "template": "qcTotalMonthTemplate", "sortable": "disabled", "resizable": "enabled", "width": 140, "headerStyle": "white-space: normal;" },
        { "headerText": "Satisfactory for the Month", "field": "qc_satisfied_month", "template": "qcSatisfiedMonthTemplate", "sortable": "disabled", "resizable": "enabled", "width": 180, "headerStyle": "white-space: normal;" },
        { "headerText": "Failed for the Month", "field": "qc_failed_month", "template": "qcFailedMonthTemplate", "sortable": "disabled", "resizable": "enabled", "width": 150, "headerStyle": "white-space: normal;" },
        { "headerText": "Total Cumulative(T)", "field": "qc_total_cumm", "template": "qcTotalCummTemplate", "sortable": "disabled", "resizable": "enabled", "width": 150, "headerStyle": "white-space: normal;" },
        { "headerText": "Satisfied Cumulative", "field": "qc_satisfied_cumm", "template": "qcSatisfiedCummTemplate", "sortable": "disabled", "resizable": "enabled", "width": 160, "headerStyle": "white-space: normal;" },
        { "headerText": "Failed Cumulative(F)", "field": "qc_total_failed", "template": "qcTotalFailedTemplate", "sortable": "disabled", "resizable": "enabled", "width": 160, "headerStyle": "white-space: normal;" },
        { "headerText": "% Failure(F/T)*100%", "field": "percent_failure", "template": "percentFailureTemplate", "sortable": "disabled", "resizable": "enabled", "width": 140, "headerStyle": "white-space: normal;" },
        { "headerText": "Major Reason for Failed Tests", "field": "failed_reason", "template": "failedReasonTemplate", "sortable": "disabled", "resizable": "enabled", "width": "", "headerStyle": "white-space: normal;" }
      ]
    },
    "disciplineColumns": {
      "type": "object[]",
      "defaultValue": [
        { "headerText": "Actions", "field": "", "template": "discActionTemplate", "frozenEdge": "start", "sortable": "disabled", "resizable": "disabled", "width": 80, "headerStyle": "white-space: normal;" },
        { "headerText": "Discipline", "field": "discipline_type", "template": "disciplineTypeTemplate", "frozenEdge": "start", "sortable": "disabled", "resizable": "enabled", "width": 150, "headerStyle": "white-space: normal;" },
        { "headerText": "Total RFI", "field": "disc_total_rfi", "template": "discTotalRfiTemplate", "sortable": "disabled", "resizable": "enabled", "width": 120, "headerStyle": "white-space: normal;" },
        { "headerText": "Approved RFI", "field": "disc_approved_rfi", "template": "discApprovedRfiTemplate", "sortable": "disabled", "resizable": "enabled", "width": 130, "headerStyle": "white-space: normal;" },
        { "headerText": "Rejected RFI", "field": "disc_rejected_rfi", "template": "discRejectedRfiTemplate", "sortable": "disabled", "resizable": "enabled", "width": 130, "headerStyle": "white-space: normal;" },
        { "headerText": "Discipline Total Cumulative (T)", "field": "disc_total_rfi_cumm", "template": "discTotalRfiCummTemplate", "sortable": "disabled", "resizable": "enabled", "width": 200, "headerStyle": "white-space: normal;" },
        { "headerText": "Approved Discipline Cumulative", "field": "disc_approved_rfi_cumm", "template": "discApprovedRfiCummTemplate", "sortable": "disabled", "resizable": "enabled", "width": 220, "headerStyle": "white-space: normal;" },
        { "headerText": "Rejected Cumulative (R)", "field": "disc_total_rfis", "template": "discTotalRfisTemplate", "sortable": "disabled", "resizable": "enabled", "width": 180, "headerStyle": "white-space: normal;" },
        { "headerText": "% Rejection(R/T)*100", "field": "percent_rejection", "template": "percentRejectionTemplate", "sortable": "disabled", "resizable": "enabled", "width": 160, "headerStyle": "white-space: normal;" },
        { "headerText": "Major Reasons for Rejected RFIs", "field": "rejected_reason", "template": "rejectedReasonTemplate", "sortable": "disabled", "resizable": "enabled", "width": "", "headerStyle": "white-space: normal;" }
      ]
    }
  },
  "eventListeners": {
    "buttonAction": {
      "chains": [
        {
          "chain": "onDisciplineEdit_Action",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "buttonAction2": {
      "chains": [
        {
          "chain": "onQualityControlEdit_AC",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "buttonAction3": {
      "chains": [
        {
          "chain": "onContinualImproveEdit_AC",
          "parameters": {
            "event": "{{$event}}",
