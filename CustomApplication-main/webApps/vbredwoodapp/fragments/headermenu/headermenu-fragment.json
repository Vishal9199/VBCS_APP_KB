{
  "description": "",
  "eventListeners": {
    "expandCollapseLinkClick": {
      "chains": [
        {
          "chain": "showMoreAC"
        }
      ]
    },
    "hyperlinkClick": {
      "chains": [
        {
          "chain": "onSelectMenu",
          "parameters": {
            "id": "[[ $current.data ]]"
          }
        }
      ]
    },
    "menuBtnAction": {
      "chains": [
        {
          "chain": "onClickMenu"
        }
      ]
    },
    "vbEnter": {
      "chains": [
        {
          "parameters": {},
          "chain": "onLoad"
        }
      ]
    }

  },
  "events": {},
  "imports": {
    "components": {
      "oj-button": {
        "path": "ojs/ojbutton"
      },
      "oj-drawer-popup": {
        "path": "ojs/ojdrawerpopup"
      },
      "oj-navigation-list": {
        "path": "ojs/ojnavigationlist"
      }
    },
    "css": [
      "/resources/css/header-menu.css"
    ]
  },
  "types": {},
  "variables": {
    "currentPage": {
      "type": "string"
    },
    "expandedNodes": {
      "type": "any"
    },
    "isShowMore": {
      "type": "boolean",
      "defaultValue": true
    },
    "loginUser": {
      "type": "string"
    },
    "menuData": {
      "type": "any"
    },
    "navigationContent": {
      "type": "any"
    },
    "openPopup": {
      "type": "boolean",
      "defaultValue": false
    },
    "pagesWoPermission": {
      "type": "string[]",
      "defaultValue": [
        "Test Page"
      ]
    }

  },
  "constants": {
    "developerUser": {
      "type": "string",
      "defaultValue": "bilal.balushi@testowwsc.nama.om"
    },
    "MenuTitle": {
      "type": "string",
      "defaultValue": "NWS Custom Application"
    }
  },
  "@dt": {
    "usedFor": [
      "page"
    ]
  }
}