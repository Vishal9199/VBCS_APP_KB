{
    "description": "Smart Search Configuration for NWS PMIS Master Plan Project Details",
    "filters": {
        "ProjectNameFilter": {
            "type": "oj-sp/smart-search/default-filters/SelectSingleFilter",
            "label": "Project Name",
            "options": {
                "field": "project_id",
                "optionsData": "[[ $search.filters.ProjectNameFilter.options.optionsData ]]",
                "optionsKeys": "[[ $search.filters.ProjectNameFilter.options.optionsKeys ]]"
            },
            "data": {}
        },
        "ReferenceNumberFilter": {
            "type": "oj-sp/smart-search/default-filters/SelectSingleFilter",
            "label": "Reference Number",
            "options": {
                "field": "mp_ref_num",
                "optionsData": "[[ $search.filters.ReferenceNumberFilter.options.optionsData ]]",
                "optionsKeys": "[[ $search.filters.ReferenceNumberFilter.options.optionsKeys ]]"
            },
            "data": {}
        },
        "RegionFilter": {
            "type": "oj-sp/smart-search/default-filters/SelectSingleFilter",
            "label": "Region",
            "options": {
                "field": "lookup_value_id",
                "optionsData": "[[ $search.filters.RegionFilter.options.optionsData ]]",
                "optionsKeys": "[[ $search.filters.RegionFilter.options.optionsKeys ]]"
            },
            "data": {}
        },
        "StatusFilter": {
            "type": "oj-sp/smart-search/default-filters/SelectSingleFilter",
            "label": "Status",
            "options": {
                "field": "active_flag",
                "optionsData": "[[ $search.filters.StatusFilter.options.optionsData ]]",
                "optionsKeys": "[[ $search.filters.StatusFilter.options.optionsKeys ]]"
            },
            "data": {}
        },
        "DateRangeFilter": {
            "type": "oj-sp/smart-search/default-filters/DateRangeFilter",
            "label": "Date Range",
            "options": {
                "field": "created_date",
                "startDate": "[[ $page.variables.p_start_date ]]",
                "endDate": "[[ $page.variables.p_end_date ]]",
                "value": "",
                "converter": {
                    "type": "datetime",
                    "options": {
                        "pattern": "dd-MMM-yyyy"
                    }
                }
            },
            "data": {
                "start": "[[ $functions.pastDate() ]]",
                "end": "[[ $functions.todayDate() ]]"
            }
        }
    }
}