{
  "title": "PAM Schedule Details Search",
  "description": "Smart Search page for PAM Schedule Details with Project, Phase, Milestone, Consultant, and Date Range filters",
  "variables": {
    "currentCount": {
      "type": "number",
      "defaultValue": 0
    },
    "currentOffset": {
      "type": "number",
      "defaultValue": 0
    },
    "currentPage": {
      "type": "number",
      "defaultValue": 1
    },
    "filterCriterion": {
      "type": "any",
      "onValueChanged": {
        "chains": [
          {
            "parameters": {
              "event": "{{ $event }}"
            },
            "chain": "filterCriterionListener"
          }
        ]
      }
    },
    "getProjectLovListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "endpoint": "PAM/getPmispamConceptstudyLovProjectname",
        "responseType": "getPmispamConceptstudyLovProjectname",
        "itemsPath": "items",
        "keyAttributes": "project_name",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "project_name"
          ]
        }
      }
    },
    "getPhaseLovListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "endpoint": "PAM/getPmispamConceptstudyLovPhase",
        "responseType": "getPmispamConceptstudyLovPhase",
        "itemsPath": "items",
        "keyAttributes": "lookup_value_name",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "lookup_value_name"
          ]
        }
      }
    },
    "getMilestoneLovListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "endpoint": "PAM/getPmispamConceptstudyLovMilestone",
        "responseType": "getPmispamConceptstudyLovMilestone",
        "itemsPath": "items",
        "keyAttributes": "lookup_value_name",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "lookup_value_name"
          ]
        }
      }
    },
    "getConsultantLovListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "endpoint": "PAM/getPmispamConceptstudyLovConsultant",
        "responseType": "getPmispamConceptstudyLovConsultant",
        "itemsPath": "items",
        "keyAttributes": "lookup_value_name",
        "transformsContext": {
          "vb-textFilterAttributes": [
            "lookup_value_name"
          ]
        }
      }
    },
    "hasNext": {
      "type": "string",
      "defaultValue": "N"
    },
    "pagination": {
      "type": "object",
      "defaultValue": {
        "is_next": false,
        "is_prev": true
      }
    },
    "paginationDisplay": {
      "type": "string",
      "defaultValue": "0 - 0 of 0 items"
    },
    "passKey": {
      "type": "string"
    },
    "passPayload": {
      "type": "string"
    },
    "searchContext": {
      "type": "object",
      "defaultValue": {
        "$search": {
          "filters": {
            "ProjectFilter": {
              "label": "Project",
              "options": {
                "optionsData": "[[ $page.variables.getProjectLovListSDP ]]",
                "optionsKeys": {
                  "label": "project_name",
                  "value": "project_id"
                }
              }
            },
            "PhaseFilter": {
              "label": "Phase",
              "options": {
                "optionsData": "[[ $page.variables.getPhaseLovListSDP ]]",
                "optionsKeys": {
                  "label": "lookup_value_name",
                  "value": "lookup_value_name"
                }
              }
            },
            "MilestoneFilter": {
              "label": "Milestone",
              "options": {
                "optionsData": "[[ $page.variables.getMilestoneLovListSDP ]]",
                "optionsKeys": {
                  "label": "lookup_value_name",
                  "value": "lookup_value_name"
                }
              }
            },
            "ConsultantFilter": {
              "label": "Consultant",
              "options": {
                "optionsData": "[[ $page.variables.getConsultantLovListSDP ]]",
                "optionsKeys": {
                  "label": "lookup_value_name",
                  "value": "lookup_value_name"
                }
              }
            },
            "DateRangeFilter": {
              "label": "Date Range"
            }
          }
        }
      }
    },
    "searchConfiguration": {
      "type": "oj-sp/smart-search/strategies/JsonSearchConfigProviderFactory",
      "defaultValue": {
        "url": "[[ $application.path + 'resources/data/pamschedulesearchconfig.json' ]]"
      }
    },
    "searchObj": {
      "type": {
        "in_limit": "string",
        "in_offset": "string",
        "p_consultant_name": "string",
        "p_milestone": "string",
        "p_phase_name": "string",
        "p_project_id": "string",
        "p_from_date": "string",
        "p_project_name": "string",
        "p_to_date": "string",
        "p_keyword": "string"

      },
      "defaultValue": {
        "in_limit": "10",
        "in_offset": "0",
        "p_project_id": "",
        "p_project_name": "",
        "p_phase_name": "",
        "p_milestone": "",
        "p_consultant_name": "",
        "p_from_date": "",
        "p_to_date": "",
        "p_keyword": ""
      }
    },
    "pamScheduleADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "PAMScheduleType",
        "keyAttributes": "cs_dtl_id"
      }
    },
    "p_start_date": {
      "type": "string"
    },
    "p_end_date": {
      "type": "string"
    },
    "selectedScheduleId": {
      "type": "number"
    },
    "showDeleteDialog": {
      "type": "boolean",
      "defaultValue": false
    },
    "deleteScheduleId": {
      "type": "number"
    },
    "totalCount": {
      "type": "number",
      "defaultValue": 0
    },
    "totalRecords": {
      "type": "number",
      "defaultValue": 0
    }

  },
  "metadata": {},
  "types": {
    "@decorators.getPmispamConceptstudyLovConsultant": {
      "endpoint": "getPmispamConceptstudyLovConsultant",
      "service": "PAM",
      "path": "response"
    },
    "@decorators.getPmispamConceptstudyLovMilestone": {
      "endpoint": "getPmispamConceptstudyLovMilestone",
      "service": "PAM",
      "path": "response"
    },
    "@decorators.getPmispamConceptstudyLovPhase": {
      "endpoint": "getPmispamConceptstudyLovPhase",
      "service": "PAM",
      "path": "response"
    },
    "@decorators.getPmispamConceptstudyLovProjectname": {
      "endpoint": "getPmispamConceptstudyLovProjectname",
      "service": "PAM",
      "path": "response"
    },
    "@decorators.getProjectLovResponse": {
      "endpoint": "getProjectLov",
      "service": "PAMScheduleService",
      "path": "response"
    },
    "@decorators.getPhaseLovResponse": {
      "endpoint": "getPhaseLov",
      "service": "PAMScheduleService",
      "path": "response"
    },
    "@decorators.getMilestoneLovResponse": {
      "endpoint": "getMilestoneLov",
      "service": "PAMScheduleService",
      "path": "response"
    },
    "@decorators.getConsultantLovResponse": {
      "endpoint": "getConsultantLov",
      "service": "PAMScheduleService",
      "path": "response"
    },
    "getPmispamConceptstudyLovConsultant": {
      "items": [
        {
          "lookup_value_code": "string",
          "lookup_value_id": "number",
          "lookup_value_name": "string"
        }
      ]
    },
    "getPmispamConceptstudyLovMilestone": {
      "items": [
        {
          "lookup_value_code": "string",
          "lookup_value_id": "number",
          "lookup_value_name": "string"
        }
      ]
    },
    "getPmispamConceptstudyLovPhase": {
      "items": [
        {
          "lookup_value_code": "string",
          "lookup_value_id": "number",
          "lookup_value_name": "string"
        }
      ]
    },
    "getPmispamConceptstudyLovProjectname": {
      "items": [
        {
          "project_id": "number",
          "project_name": "string"
        }
      ]
    },
    "getProjectLovResponse": {
      "items": [
        {
          "project_id": "number",
          "project_name": "string"
        }
      ]
    },
    "getPhaseLovResponse": {
      "items": [
        {
          "phase_id": "number",
          "phase_name": "string"
        }
      ]
    },
    "getMilestoneLovResponse": {
      "items": [
        {
          "milestone_id": "number",
          "milestone_name": "string"
        }
      ]
    },
    "getConsultantLovResponse": {
      "items": [
        {
          "consultant_id": "number",
          "consultant_name": "string"
        }
      ]
    },
    "PAMScheduleType": {
      "cs_dtl_id": "number",
      "milestone": "string",
      "object_version_num": "number",
      "planning_manager_name": "string",
      "project_id": "number",
      "project_name": "string",
      "phase_id": "number",
      "phase_name": "string",
      "milestone_id": "number",
      "cs_senior_mgr_id": "number",
      "senior_manager_name": "string",
      "cs_planning_mgr_id": "number",
      "consultant_id": "number",
      "consultant_name": "string",
      "budget_amount": "number",
      "planned_start_date": "string",
      "planned_end_date": "string",
      "revised_start_date": "string",
      "revised_end_date": "string",
      "actual_start_date": "string",
      "actual_end_date": "string",
      "completion_percentage": "number",
      "remarks": "string",
      "created_by": "string",
      "creation_date": "string",
      "last_updated_by": "string",
      "last_update_date": "string"

    }

  },
  "imports": {
    "components": {
      "oj-button": {
        "path": "ojs/ojbutton"
      },
      "oj-input-date": {
        "path": "ojs/ojdatetimepicker"
      },
      "oj-input-text": {
        "path": "ojs/ojinputtext"
      },
      "oj-bind-text": {
        "path": "ojs/ojbindtext"
      },
      "oj-bind-if": {
        "path": "ojs/ojbindif"
      },
      "oj-progress-circle": {
        "path": "ojs/ojprogress-circle"
      },
      "oj-sp-smart-search": {
        "path": "oj-sp/smart-search/loader"
      },
      "oj-sp-smart-search-page": {
        "path": "oj-sp/smart-search-page/loader"
      },
      "oj-table": {
        "path": "ojs/ojtable"
      },
      "oj-dialog": {
        "path": "ojs/ojdialog"
      },
      "oj-progress-bar": {
        "path": "ojs/ojprogressbar"
      }

    },
    "modules": {
      "ojValidationDateTime": {
        "path": "ojs/ojvalidation-datetime"
      }
    },
    "css": [
      "/resources/css/pmis-search.css"
    ]
  },
  "eventListeners": {
    "buttonAction": {
      "chains": [
        {
          "chain": "onEditAction",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "buttonAction2": {
      "chains": [
        {
          "chain": "onDeleteAction",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "buttonAction3": {
      "chains": [
        {
          "chain": "okdeleteaction",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "buttonAction4": {
      "chains": [
        {
          "chain": "canceldeleteaction",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "createBtnAction": {
      "chains": [
        {
          "chain": "createactionchain",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "nextBtnAction": {
      "chains": [
        {
          "chain": "nextbuttonaction",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "prevBtnAction": {
      "chains": [
        {
          "chain": "previousbuttonaction",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "refreshBtnAction": {
      "chains": [
        {
          "chain": "refreshactionchain",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "resetBtnAction": {
      "chains": [
        {
          "chain": "resetbuttonaction",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "vbEnter": {
      "chains": [
        {
          "parameters": {},
          "chain": "vbEnterListener"
        }
      ]
    }

  },
  "constants": {
