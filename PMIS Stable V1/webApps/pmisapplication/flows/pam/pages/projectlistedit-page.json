  "variables": {
    "aToolBar": {
      "type": "object[]",
      "defaultValue": [
        {
          "label": "Save",
          "id": "save",
          "icon": "oj-ux-ico-save"
        },
        {
          "label": "Save & Close",
          "id": "saveClose",
          "icon": "oj-ux-ico-save-and-close"
        },
