          "icon": "oj-ux-ico-information"
        }
      ],
        "uniqueItems": true
    },
    "toolDraft": {
      "type": "object[]",
      "defaultValue": [
        {
          "label": "Save",
          "id": "save",
          "icon": "oj-ux-ico-save"
        },
        {
          "label": "Submit",
          "id": "submit",
          "icon": "oj-ux-ico-success"
        },
        {
          "label": "Save & Close",
          "id": "saveClose",
          "icon": "oj-ux-ico-save-and-close"
        },
        {
          "label": "Approval History",
          "id": "approvalHistory",
          "icon": "oj-ux-ico-clock-history"
        },
{
          "label": "Attachment",
          "id": "attachment",
          "icon": "oj-ux-ico-attachment"
        },
        {
          "label": "About",
          "id": "about",
          "icon": "oj-ux-ico-information"
        }
