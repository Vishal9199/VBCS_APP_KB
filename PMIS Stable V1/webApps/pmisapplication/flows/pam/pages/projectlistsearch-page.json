{
  "title": "Search Project Details",
  "description": "Smart Search page for NWS PMIS Master Plan Project Details with comprehensive filtering and search capabilities",
  "variables": {
    "filterCriterion": {
      "type": "any",
      "onValueChanged": {
        "chains": [
          {
            "parameters": {
              "event": "{{ $event }}"
            },
            "chain": "filterCriterionListener"
          }
        ]
      }
    },
    "lovProjectNameSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "responseType": "getPmispamLovMasterplanProjectname",
        "itemsPath": "items",
        "keyAttributes": "project_id",
        "fetchChain": "getPmispamLovMasterplanProjectnameFetch"
      }
    },
    "lovRefNumSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "responseType": "getPmispamLovMasterplanReferenceno",
        "itemsPath": "items",
        "keyAttributes": "mp_ref_num",
        "fetchChain": "getPmispamLovMasterplanReferencenoFetch"
      }
    },
    "lovRegionSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {

        "responseType": "getPmisLovRegionName",
        "itemsPath": "items",
        "keyAttributes": "lookup_value_id",
        "fetchChain": "getPmisLovRegionNameFetch"
      }
    },
    "pagination": {
      "type": "object",
      "defaultValue": {
        "is_next": false,
        "is_prev": true
      }
    },
    "paginationDisplay": {
      "type": "string",
      "defaultValue": "0 - 0 of 0 items"
    },
    "passProjectDtlsVar": {
      "type": {
        "mpName": "string",
        "mpRefId": "string",
        "refNum": "string"

      },
      "defaultValue": {
        "refNum": "0",
        "mpName": "0",
        "mpRefId": "0"
      }
    },
    "totalRecords": {
      "type": "number",
      "defaultValue": 0
    },
    "currentPage": {
      "type": "number",
      "defaultValue": 1
    },
    "searchContext": {
      "type": "object",
      "defaultValue": {
        "$search": {
          "filters": {
            "ProjectNameFilter": {
              "label": "Project Name",
              "options": {
                "optionsData": "[[ $variables.lovProjectNameSDP ]]",
                "optionsKeys": {
                  "label": "project_name",
                  "value": "project_id"
                }
              }
            },
            "ReferenceNumberFilter": {
              "label": "Reference Number",
              "options": {
                "optionsData": "[[ $variables.lovRefNumSDP ]]",
                "optionsKeys": {
                  "label": "mp_ref_num",
                  "value": "mp_ref_num"
                }
              }
            },
            "RegionFilter": {
              "label": "Region",
              "options": {
                "optionsData": "[[ $variables.lovRegionSDP ]]",
                "optionsKeys": {
                  "label": "lookup_value_name",
                  "value": "lookup_value_id"
                }
              }
            },
            "StatusFilter": {
              "label": "Status",
              "options": {
                "optionsData": "[[ $variables.lovStatusADP ]]",
                "optionsKeys": {
                  "label": "status_label",
                  "value": "active_flag"
                }
              }
            },
            "DateRangeFilter": {
              "label": "Date Range"
            }
          }
        }
      }
    },
    "searchConfiguration": {
      "type": "oj-sp/smart-search/strategies/JsonSearchConfigProviderFactory",
      "defaultValue": {
        "url": "[[ $application.path + 'resources/data/projectsearchconfig.json' ]]"
      }
    },
    "searchObj": {
      "type": {
        "in_limit": "string",
        "in_offset": "string",
        "p_keyword": "string",
        "p_project_id": "string",
        "p_mp_ref_num": "string",
        "p_project_name": "string",
        "p_project_type": "string",
        "p_region_id": "string",
        "p_status": "string",
        "p_from_date": "string",
        "p_to_date": "string",
        "p_created_by_user": "string"

      },
      "defaultValue": {
        "in_limit": "10",
        "in_offset": "0",
        "p_keyword": "",
        "p_project_id": "",
        "p_mp_ref_num": "",
        "p_project_name": "",
        "p_project_type": "",
        "p_status": "",
        "p_region_id": "",
        "p_from_date": "",
        "p_to_date": "",
        "p_created_by_user": ""

      }
    },
    "projectDetailsADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "ProjectDetailsType",
        "keyAttributes": "project_id"
      }
    },
    "currentOffset": {
      "type": "number",
      "defaultValue": 0
    },
    "hasNext": {
      "type": "string",
      "defaultValue": "N"
    },
    "totalCount": {
      "type": "number",
      "defaultValue": 0
    },
    "currentCount": {
      "type": "number",
      "defaultValue": 0
    },
    "p_start_date": {
      "type": "string"
    },
    "p_end_date": {
      "type": "string"
    },
    "lovStatusADP": {
  "type": "vb/ArrayDataProvider2",
  "defaultValue": {
    "data": [
      { "active_flag": "Y", "status_label": "Active" },
      { "active_flag": "N", "status_label": "Inactive" }
    ],
    "keyAttributes": "active_flag"
  }
}

  },
  "metadata": {},
  "types": {
    "@decorators.getPmisLovRegionName": {
      "endpoint": "getPmisLovRegionName",
      "service": "PmisSetup",
      "path": "response"
    },
    "@decorators.getPmispamLovMasterplanProjectname": {
      "endpoint": "getPmispamLovMasterplanProjectname",
      "service": "PAM",
      "path": "response"
    },
    "@decorators.getPmispamLovMasterplanReferenceno": {
      "endpoint": "getPmispamLovMasterplanReferenceno",
      "service": "PAM",
      "path": "response"
    },
    "@decorators.ProjectDetailsType": {
      "endpoint": "getProjectDetails",
      "service": "ProjectDetailsService",
      "path": "response"
    },
    "@decorators.ProjectDetailsTypeOLD": {
      "endpoint": "getProjectDetails",
      "service": "ProjectDetailsService",
      "path": "response"
    },
    "getPmisLovRegionName": {
      "items": [
        {
          "lookup_value_code": "string",
          "lookup_value_id": "number",
          "lookup_value_name": "string"
        }
      ]
    },
    "getPmispamLovMasterplanProjectname": {
      "items": [
        {
          "project_id": "number",
          "project_long_name": "string",
          "project_name": "string"
        }
      ]
    },
    "getPmispamLovMasterplanReferenceno": {
      "items": [
        {
          "mp_ref_id": "number",
          "mp_ref_num": "string",
          "mp_ref_plan_name": "string"
        }
      ]
    },
    "ProjectDetailsType": {
      "project_id": "number",
      "object_version_num": "number",
      "mp_ref_id": "number",
      "mp_ref_num": "string",
      "mp_ref_plan_name": "string",
      "project_type_id": "number",
      "project_type": "string",
      "project_category_id": "number",
      "project_category": "string",
      "project_name": "string",
      "project_long_name": "string",
      "region_id": "number",
      "region_name": "string",
      "project_location_id": "number",
      "project_location": "string",
      "category_id": "number",
      "category": "string",
      "description": "string",
      "five_year_prj_flag": "string",
      "latest_est_budget_val": "number",
      "scp_approved_budget_val": "number",
      "active_flag": "string",
      "inactive_date": "string",
      "budget_year_id": "number",
      "calendar_name": "string",
      "comments": "string",
      "additional_info": "string",
      "created_by": "string",
      "created_date": "string",
      "last_updated_by": "string",
      "last_updated_date": "string",
      "last_updated_login": "string"
    },
    "ProjectDetailsTypeOLD": {
      "project_id": "number",
      "object_version_num": "number",
      "mp_ref_id": "number",
      "mp_ref_num": "string",
      "mp_ref_plan_name": "string",
      "project_type_id": "number",
      "project_category_id": "number",
      "project_name": "string",
      "project_long_name": "string",
      "region_id": "number",
      "project_location_id": "number",
      "category_id": "number",
      "description": "string",
      "five_year_prj_flag": "string",
      "latest_est_budget_val": "number",
      "scp_approved_budget_val": "number",
      "active_flag": "string",
      "inactive_date": "string",
      "budget_year_id": "number",
      "comments": "string",
      "additional_info": "string",
      "created_by": "string",
      "created_date": "string",
      "last_updated_by": "string",
      "last_updated_date": "string",
      "last_updated_login": "string"
    }

  },
  "eventListeners": {
    "addProjectBtnAction": {
      "chains": [
        {
          "chain": "onAddProjectBtnAction",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "buttonAction": {
      "chains": [
        {
          "chain": "onEditAction",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "buttonAction2": {
      "chains": [
        {
          "chain": "onDeleteAction",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "closeLovDialog": {
      "chains": [
        {
          "chain": "closeLovDialog",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "confirmLovSelection": {
      "chains": [
        {
          "chain": "confirmLovSelection",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "resetBtnAction": {
    "chains": [
      {
        "chain": "resetSearchAction"
      }
    ]
  },
  "refreshBtnAction": {
    "chains": [
      {
        "chain": "refreshSearchAction"
      }
    ]
  },
  "exportBtnAction": {
    "chains": [
      {
        "chain": "exportToExcelAction"
      }
    ]
  },
  "createBtnAction": {
    "chains": [
      {
        "chain": "createProjectAction"
      }
    ]
  },
  "preBtnAction": {
    "chains": [
      {
        "chain": "previousPageAction"
      }
    ]
  },
  "nxtBtnAction": {
    "chains": [
      {
        "chain": "nextPageAction"
      }
    ]
  },
    "selectValueItem": {
      "chains": [
        {
          "chain": "onLovDialogRefNumValue",
          "parameters": {
            "event": "{{$event}}",
            "previousValue": "{{$event.detail.previousValue}}",
            "value": "{{$event.detail.value}}",
            "updatedFrom": "{{$event.detail.updatedFrom}}",
            "key": "{{$event.detail.value.key}}",
            "data": "{{$event.detail.value.data}}",
            "metadata": "{{$event.detail.value.metadata}}",
            "valueItem": "{{ $event.detail.value }}"
          }
        }
      ]
    },
    "vbEnter": {
    "chains": [
      {
        "chain": "vbEnterListener"
      }
    ]
  }

},
