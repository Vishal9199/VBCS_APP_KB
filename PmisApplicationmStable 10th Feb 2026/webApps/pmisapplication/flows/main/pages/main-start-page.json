  "eventListeners": {
    "pamListItemAction": {
      "chains": [
        {
          "chain": "ListViewItemActionChain",
          "parameters": {
            "event": "{{$event}}",
            "eventContext": "{{$event.detail.context}}",
            "originalEvent": "{{$event.detail.originalEvent}}",
            "key": "{{$event.detail.context.data.key}}"
          }
        }
      ]
    },
    "pddsetuplist": {
     "chains": [
        {
          "chain": "pddsetupactions",
          "parameters": {
            "event": "{{$event}}",
            "eventContext": "{{$event.detail.context}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "pmisSetupListItemAction": {
      "chains": [
        {
          "chain": "pmisSetupActions",
          "parameters": {
            "event": "{{$event}}",
            "eventContext": "{{$event.detail.context}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    }

  },
