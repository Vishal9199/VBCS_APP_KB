{
    "description": "Smart Search Configuration for Project Milestone Tracking",
    "filters": {
        "ProjectFilter": {
            "type": "oj-sp/smart-search/default-filters/SelectSingleFilter",
            "label": "Project",
            "options": {
                "field": "p_project_name",
                "optionsData": "[[ $page.variables.getProjectLovListSDP ]]",
                "optionsKeys": {
                    "label": "project_name",
                    "value": "project_name"
                }
            },
            "data": {}
        },
        "PhaseFilter": {
            "type": "oj-sp/smart-search/default-filters/SelectSingleFilter",
            "label": "Phase",
            "options": {
                "field": "p_phase_name",
                "optionsData": "[[ $page.variables.getPhaseLovListSDP ]]",
                "optionsKeys": {
                    "label": "lookup_value_name",
                    "value": "lookup_value_name"
                }
            },
            "data": {}
        },
        "MilestoneFilter": {
            "type": "oj-sp/smart-search/default-filters/SelectSingleFilter",
            "label": "Milestone",
            "options": {
                "field": "p_milestone",
                "optionsData": "[[ $page.variables.getMilestoneLovListSDP ]]",
                "optionsKeys": {
                    "label": "lookup_value_name",
                    "value": "lookup_value_name"
                }
            },
            "data": {}
        },
        "ConsultantFilter": {
            "type": "oj-sp/smart-search/default-filters/SelectSingleFilter",
            "label": "Consultant",
            "options": {
                "field": "p_consultant_name",
                "optionsData": "[[ $page.variables.getConsultantLovListSDP ]]",
                "optionsKeys": {
                    "label": "lookup_value_name",
                    "value": "lookup_value_name"
                }
            },
            "data": {}
        },
        "DateRangeFilter": {
            "type": "oj-sp/smart-search/default-filters/DateRangeFilter",
            "label": "Date Range",
            "options": {
                "field": "planned_start_date",
                "startDate": "[[ $page.variables.p_planned_start_date ]]",
                "endDate": "[[ $page.variables.p_planned_end_date ]]",
                "value": "",
                "converter": {
                    "type": "datetime",
                    "options": {
                        "pattern": "dd-MMM-yyyy"
                    }
                }
            },
            "data": {
                "start": "[[ $functions.pastDate() ]]",
                "end": "[[ $functions.todayDate() ]]"
            }
        }
    },
    "searchOptions": {
        "keywordField": "p_keyword",
        "limit": "[[ $page.variables.IN_LIMIT ]]",
        "offset": "[[ $page.variables.IN_OFFSET ]]"
    }
}